---
import ExperimentCard from '../components/ExperimentCard.astro';
import CustomSection from '../components/CustomSection.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillBadge from '../components/SkillBadge.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPortfolioData } from '../lib/portfolio-data';
import { themeClass, themeStyleAttribute } from '../lib/theme';

const { config, projects, skills, experiments, sections } = await getPortfolioData();
const featuredProject = projects.find((project) => project.featured) ?? projects[0];
const featuredCount = projects.filter((project) => project.featured).length;
const designClass = `design-${config.design_variant}`;
const themeClasses = themeClass(config.theme_json);
const themeStyle = themeStyleAttribute(config.theme_json);
const skillGroups =
  skills.length > 0
    ? skills
    : [
        {
          category: 'Frontend Systems',
          items: ['Flutter Web', 'Astro SSG', 'Responsive UI', 'Design Systems'],
        },
        {
          category: 'Realtime Networks',
          items: ['WebRTC', 'P2P Signaling', 'Supabase', 'Operational Debugging'],
        },
        {
          category: 'Agentic Workflows',
          items: ['AI Orchestration', 'Prompt Systems', 'Tooling', 'Automation'],
        },
      ];
const quickFacts = [
  ['Role', 'Flutter Software Engineer', 'Cross-platform app delivery with clean UI and Firebase-backed workflows.'],
  ['Focus', 'Mobile + Product UI', 'Flutter, responsive interfaces, API handling, and practical state management.'],
  ['Leadership', 'Mentor + Community Lead', 'GDSC Flutter Head, ICPC core team member, and programming instructor.'],
  ['Education', 'Computer Science Graduate', 'Bachelor of Computer Science, AEA Academy, July 2024.'],
];
const queuedLab = [
  ['Flutter Workshops', 'Led Flutter learning sessions and mentored student developers.'],
  ['Programming Instruction', 'Designed lessons to simplify programming and software fundamentals.'],
  ['ICPC Volunteering', 'Organized problem-solving contests and supported new members.'],
];
const sectionsFor = (placement: string) =>
  sections.filter((section) => section.placement === placement);
---

<BaseLayout title={`${config.name} | Portfolio`} description={config.headline}>
  <main class={`${designClass} ${themeClasses}`} style={themeStyle}>
    <HeroSection
      config={config}
      projectCount={projects.length}
      skillCount={skillGroups.length}
      experimentCount={experiments.length}
      featuredProject={featuredProject}
    />

    {sectionsFor('after_hero').map((section) => <CustomSection section={section} />)}

    <section class="border-b border-line bg-panel px-6 py-10 lg:px-8" id="summary">
      <div class="mx-auto max-w-7xl">
        <SectionHeader
          eyebrow="30-Second Summary"
          title="What Recruiters Need To Know Fast"
          copy="Flutter engineer with practical app delivery, Firebase experience, mentorship history, and computer science fundamentals."
        />
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {quickFacts.map(([label, title, copy]) => (
            <article class="border border-line bg-white p-5">
              <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-alert">
                {label}
              </p>
              <h3 class="mt-4 text-2xl font-black text-ink">{title}</h3>
              <p class="mt-3 text-sm leading-7 text-quiet">{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {sectionsFor('before_projects').map((section) => <CustomSection section={section} />)}

    <section class="border-b border-line bg-white px-6 py-12 lg:px-8" id="projects">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-6 border-b border-line pb-8 lg:flex-row lg:items-end">
          <SectionHeader
            eyebrow="Selected Projects"
            title="Relevant Flutter Projects"
            copy="Two quick project examples from the resume, focused on the role, stack, and practical delivery value."
          />
          <div class="grid w-full max-w-md grid-cols-2 border border-line bg-panel">
            <div class="border-r border-line p-4">
              <p class="font-mono text-xs font-black uppercase tracking-[0.14em] text-quiet">
                Projects
              </p>
              <p class="mt-1 text-4xl font-black text-ink">{projects.length}</p>
            </div>
            <div class="p-4">
              <p class="font-mono text-xs font-black uppercase tracking-[0.14em] text-quiet">
                Featured
              </p>
              <p class="mt-1 text-4xl font-black text-ink">{featuredCount}</p>
            </div>
          </div>
        </div>

        <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {projects.map((project, index) => (
            <ProjectCard project={project} prominent={index === 0} index={index} />
          ))}
          {projects.length === 0 && (
            <div class="border border-line bg-panel p-6">
              <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-alert">
                Awaiting Project
              </p>
              <p class="mt-4 text-sm leading-7 text-quiet">
                Publish the first project from the dashboard.
              </p>
            </div>
          )}
        </div>
      </div>
    </section>

    {sectionsFor('before_lab').map((section) => <CustomSection section={section} />)}

    <section class="border-b border-line bg-ink px-6 py-12 text-white lg:px-8" id="experience">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col justify-between gap-6 border-b border-white/15 pb-8 lg:flex-row lg:items-end">
          <SectionHeader
            eyebrow="Experience And Leadership"
            title="Teaching, Community Work, And Technical Leadership"
            copy="Relevant proof beyond projects: Flutter workshops, ICPC volunteering, mentoring, and programming instruction."
            inverse
          />
          <a class="border border-white/25 px-5 py-3 text-sm font-black text-white" href="#contact">
            Contact
          </a>
        </div>

        <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {experiments.map((experiment) => (
            <ExperimentCard experiment={experiment} href={`lab/${experiment.slug}/`} />
          ))}
          {experiments.length === 0 &&
            queuedLab.map(([title, copy]) => (
              <article class="border border-white/15 bg-white/5 p-5">
                <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-alert">
                  Experience
                </p>
                <h3 class="mt-4 text-2xl font-black text-white">{title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-300">{copy}</p>
              </article>
            ))}
        </div>
      </div>
    </section>

    {sectionsFor('before_skills').map((section) => <CustomSection section={section} />)}

    <section class="border-b border-line bg-panel px-6 py-12 lg:px-8" id="skills">
      <div class="mx-auto max-w-7xl">
        <SectionHeader
          eyebrow="Skills"
          title="Core Skills"
          copy="Grouped for fast screening."
        />
        <div class="grid gap-5 lg:grid-cols-3">
          {skillGroups.map((skill) => (
            <article class="border border-line bg-white p-5">
              <div class="mb-5 flex items-center justify-between gap-4 border-b border-line pb-4">
                <h3 class="text-xl font-black text-ink">{skill.category}</h3>
                <span class="font-mono text-xs font-black uppercase tracking-[0.14em] text-alert">
                  {skill.items.length} skills
                </span>
              </div>
              <div class="flex flex-wrap gap-2">
                {skill.items.map((item) => <SkillBadge label={item} />)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {sectionsFor('before_contact').map((section) => <CustomSection section={section} />)}

    <section class="bg-ink px-6 py-12 text-white lg:px-8" id="contact">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1fr_0.72fr] lg:items-end">
        <div>
          <p class="font-mono text-xs font-black uppercase tracking-[0.18em] text-signal">
            Contact
          </p>
          <h2 class="mt-4 max-w-3xl text-4xl font-black leading-tight sm:text-6xl">
            Want the resume or a quick conversation?
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-slate-300">
            The fastest path is email, resume, LinkedIn, or GitHub.
          </p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          {config.email && (
            <a class="bg-white px-5 py-3 text-sm font-black text-ink" href={`mailto:${config.email}`}>
              Email
            </a>
          )}
          {config.resume_url && (
            <a class="border border-white/25 px-5 py-3 text-sm font-black text-white" href={config.resume_url}>
              Resume
            </a>
          )}
          {config.github_url && (
            <a class="border border-white/25 px-5 py-3 text-sm font-black text-white" href={config.github_url}>
              GitHub
            </a>
          )}
          {config.linkedin_url && (
            <a class="border border-white/25 px-5 py-3 text-sm font-black text-white" href={config.linkedin_url}>
              LinkedIn
            </a>
          )}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
