---
import ExperimentCard from '../components/ExperimentCard.astro';
import CustomSection from '../components/CustomSection.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectProofSection from '../components/ProjectProofSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillBadge from '../components/SkillBadge.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPortfolioData } from '../lib/portfolio-data';
import { normalizeThemeConfig, themeClass, themeStyleAttribute } from '../lib/theme';

const { config, projects, skills, experiments, sections } = await getPortfolioData();
const featuredProject = projects.find((project) => project.featured) ?? projects[0];
const featuredCount = projects.filter((project) => project.featured).length;
const designClass = `design-${config.design_variant}`;
const theme = normalizeThemeConfig(config.theme_json);
const themeClasses = themeClass(theme);
const themeStyle = themeStyleAttribute(theme);
const phoneHref = config.phone ? `tel:${config.phone.replace(/[^\d+]/g, '')}` : null;
const contactActions = [
  { label: 'Email', href: config.email ? `mailto:${config.email}` : null, icon: 'email' },
  { label: 'Resume', href: config.resume_url, icon: 'resume', download: true },
  { label: 'Phone', href: phoneHref, icon: 'phone' },
  { label: 'GitHub', href: config.github_url, icon: 'github' },
  { label: 'LinkedIn', href: config.linkedin_url, icon: 'linkedin' },
  { label: 'Instagram', href: config.instagram_url, icon: 'instagram' },
].filter((item) => item.href) as {
  label: string;
  href: string;
  icon: string;
  download?: boolean;
}[];
const skillGroups =
  skills.length > 0
    ? skills
    : [
        {
          category: 'Frontend Systems',
          items: ['Flutter Web', 'Astro SSG', 'Responsive UI', 'Design Systems'],
        },
        {
          category: 'Realtime Networks',
          items: ['WebRTC', 'P2P Signaling', 'Supabase', 'Operational Debugging'],
        },
        {
          category: 'Agentic Workflows',
          items: ['AI Orchestration', 'Prompt Systems', 'Tooling', 'Automation'],
        },
      ];
const queuedLab: [string, string][] = [
  ['AI Workflow Automation', 'Built n8n workflows that connect LLM APIs, webhooks, external services, and smart notifications.'],
  ['Flutter Workshops', 'Led Flutter learning sessions and mentored student developers.'],
  ['Programming Instruction', 'Designed lessons to simplify programming and software fundamentals.'],
  ['ICPC Volunteering', 'Organized problem-solving contests and supported new members.'],
];
const hiddenSectionKeys = new Set(['ai-builder-summary']);
const sectionsFor = (placement: string) =>
  sections.filter((section) => section.placement === placement && !hiddenSectionKeys.has(section.section_key));
---

<BaseLayout title={`${config.name} | Portfolio`} description={config.headline}>
  <main class={`${designClass} ${themeClasses}`} style={themeStyle}>
    <HeroSection
      config={config}
      theme={theme}
      projects={projects}
      featuredProject={featuredProject}
    />

    {sectionsFor('after_hero').map((section) => <CustomSection section={section} />)}

    {sectionsFor('before_projects').map((section) => <CustomSection section={section} />)}
    <ProjectProofSection
      projects={projects}
      featuredCount={featuredCount}
      cardStyle={theme.projectCardStyle}
    />

    {sectionsFor('before_lab').map((section) => <CustomSection section={section} />)}

    <section class="portfolio-experience" id="experience">
      <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
        <div class="flex flex-col justify-between gap-6 border-b border-white/10 pb-8 lg:flex-row lg:items-end">
          <SectionHeader
            eyebrow="Experience And Leadership"
            title="Teaching, Community Work, And Technical Leadership"
            copy="Relevant proof beyond projects: Flutter workshops, ICPC volunteering, mentoring, and programming instruction."
            inverse
          />
          <a class="portfolio-button" href="#contact">
            Contact
          </a>
        </div>

        <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {experiments.map((experiment) => (
            <ExperimentCard experiment={experiment} href={`lab/${experiment.slug}/`} />
          ))}
          {experiments.length === 0 &&
            queuedLab.map(([title, copy]) => (
              <article class="portfolio-fallback-card">
                <p>
                  Experience
                </p>
                <h3>{title}</h3>
                <span>{copy}</span>
              </article>
            ))}
        </div>
      </div>
    </section>

    {sectionsFor('before_skills').map((section) => <CustomSection section={section} />)}

    <section class="portfolio-skills" id="skills">
      <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
        <SectionHeader
          eyebrow="Skills"
          title="Core Skills"
          copy="Grouped for fast screening."
          inverse
        />
        <div class="grid gap-5 lg:grid-cols-3">
          {skillGroups.map((skill) => (
            <article class="portfolio-skill-card">
              <div>
                <h3>{skill.category}</h3>
                <span>
                  {skill.items.length} skills
                </span>
              </div>
              <div class="portfolio-skill-card__badges">
                {skill.items.map((item) => <SkillBadge label={item} />)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {sectionsFor('before_contact').map((section) => <CustomSection section={section} />)}

    <section class="portfolio-contact" id="contact">
      <div class="mx-auto grid max-w-7xl gap-8 px-5 py-16 sm:px-6 lg:grid-cols-[1fr_0.72fr] lg:items-end lg:px-8">
        <div>
          <p>
            Contact
          </p>
          <h2>
            Want the resume or a quick conversation?
          </h2>
          <p class="portfolio-contact__copy">
            Use whichever channel is fastest for you.
          </p>
        </div>
        <div class="portfolio-contact__links">
          {contactActions.map((link) => (
            <a href={link.href} download={link.download}>
              <span class="portfolio-button__icon" aria-hidden="true" data-icon={link.icon}>
                {link.icon === 'resume' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M7 3h7l4 4v14H7z"></path>
                    <path d="M14 3v5h4"></path>
                    <path d="M9 13h6"></path>
                    <path d="M9 17h4"></path>
                  </svg>
                )}
                {link.icon === 'email' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M4 6h16v12H4z"></path>
                    <path d="m4 7 8 6 8-6"></path>
                  </svg>
                )}
                {link.icon === 'phone' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M8 4 6 6c0 7 5 12 12 12l2-2-4-4-2 2c-2-1-3-2-4-4l2-2z"></path>
                  </svg>
                )}
                {link.icon === 'github' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M9 19c-4 1-4-2-5-3"></path>
                    <path d="M15 22v-3c0-1 .2-1.7-.5-2 2.7-.3 5.5-1.4 5.5-6A4.6 4.6 0 0 0 18.7 8c.1-.3.6-1.7-.1-3.4 0 0-1-.3-3.5 1.3a12 12 0 0 0-6.2 0C6.4 4.3 5.4 4.6 5.4 4.6 4.7 6.3 5.2 7.7 5.3 8A4.6 4.6 0 0 0 4 11c0 4.6 2.8 5.7 5.5 6-.7.3-.8 1-.8 2v3"></path>
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M6 9v10"></path>
                    <path d="M6 5v.01"></path>
                    <path d="M11 19v-6a4 4 0 0 1 8 0v6"></path>
                    <path d="M11 9v10"></path>
                  </svg>
                )}
                {link.icon === 'instagram' && (
                  <svg viewBox="0 0 24 24">
                    <rect x="5" y="5" width="14" height="14" rx="4"></rect>
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M16.5 7.5h.01"></path>
                  </svg>
                )}
              </span>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
