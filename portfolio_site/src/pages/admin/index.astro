---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin-dashboard.css';

const supabaseUrl = import.meta.env.SUPABASE_URL?.trim() ?? '';
const supabaseAnonKey = import.meta.env.SUPABASE_ANON_KEY?.trim() ?? '';
---

<BaseLayout title="Portfolio Admin" description="Secure dashboard for managing portfolio content.">
  <main class="admin-shell" data-supabase-url={supabaseUrl} data-supabase-anon-key={supabaseAnonKey}>
    <div class="admin-container">
      <header class="admin-hero">
        <div class="admin-kicker">Portfolio Admin</div>
        <h1 class="admin-title">Manage the live portfolio content without touching the public UI.</h1>
        <p class="admin-subtitle">
          This dashboard edits the same Supabase-backed content that powers the published site.
          The public portfolio layout stays untouched; only the content records change.
        </p>
        <div class="admin-banner">
          <span><strong>Scope:</strong> site config, projects, skills, experiments, page sections</span>
          <span><strong>Auth:</strong> Supabase email login</span>
          <span><strong>Publish model:</strong> update data here, then rebuild the portfolio site</span>
        </div>
      </header>

      <section id="admin-login" class="admin-card">
        <div class="admin-card__header">
          <div>
            <h2>Sign in</h2>
            <p>Only users listed in `admin_users` can edit content.</p>
          </div>
        </div>
        <div class="admin-card__body">
          <form class="admin-auth" id="login-form">
            <div class="admin-field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" autocomplete="email" required />
            </div>
            <div class="admin-field">
              <label for="password">Password</label>
              <input id="password" name="password" type="password" autocomplete="current-password" required />
            </div>
            <div class="admin-actions">
              <button class="admin-button admin-button--primary" type="submit">Sign in</button>
            </div>
            <p class="admin-status" id="login-status"></p>
          </form>
        </div>
      </section>

      <section id="admin-app" class="admin-grid admin-hidden" aria-live="polite">
        <aside class="admin-card">
          <div class="admin-card__header">
            <div>
              <h2>Content Areas</h2>
              <p>Select what you want to edit.</p>
            </div>
          </div>
          <div class="admin-card__body">
            <div class="admin-tabs" role="tablist" aria-label="Content sections">
              <button class="admin-tab" type="button" data-tab="site-config" aria-selected="true">Site Config</button>
              <button class="admin-tab" type="button" data-tab="projects" aria-selected="false">Projects</button>
              <button class="admin-tab" type="button" data-tab="skills" aria-selected="false">Skills</button>
              <button class="admin-tab" type="button" data-tab="experiments" aria-selected="false">Experiments</button>
              <button class="admin-tab" type="button" data-tab="sections" aria-selected="false">Sections</button>
            </div>

            <div style="margin-top: 18px;">
              <button class="admin-button admin-button--ghost" type="button" id="refresh-button">Refresh data</button>
              <button class="admin-button admin-button--danger" type="button" id="signout-button" style="margin-left: 8px;">Sign out</button>
            </div>

            <div style="margin-top: 18px;">
              <button class="admin-button admin-button--primary" type="button" id="publish-button">Save + Publish</button>
            </div>

            <p class="admin-status" id="app-status"></p>
          </div>
        </aside>

        <div class="admin-stack">
          <section class="admin-card">
            <div class="admin-card__header">
              <div>
                <h3>Publish Log</h3>
                <p>Recent deploy attempts and their current state.</p>
              </div>
            </div>
            <div class="admin-card__body">
              <div class="admin-list" id="publish-log-list"></div>
              <div class="admin-empty admin-hidden" id="publish-log-empty">No publish attempts yet.</div>
              <p class="admin-status" id="publish-log-status"></p>
            </div>
          </section>

          <section class="admin-card" data-panel="site-config">
            <div class="admin-card__header">
              <div>
                <h3>Site Config</h3>
                <p>Update the title, bio, and top-level links.</p>
              </div>
            </div>
            <div class="admin-card__body">
              <form class="admin-grid-form" id="site-config-form">
                <div class="admin-field">
                  <label for="site-name">Name</label>
                  <input id="site-name" name="name" type="text" required />
                </div>
                <div class="admin-field">
                  <label for="site-headline">Headline</label>
                  <input id="site-headline" name="headline" type="text" required />
                </div>
                <div class="admin-field admin-field--full">
                  <label for="site-bio">Bio</label>
                  <textarea id="site-bio" name="bio" required></textarea>
                </div>
                <div class="admin-field">
                  <label for="site-resume">Resume URL</label>
                  <input id="site-resume" name="resume_url" type="url" />
                </div>
                <div class="admin-field">
                  <label for="site-email">Email</label>
                  <input id="site-email" name="email" type="email" />
                </div>
                <div class="admin-field">
                  <label for="site-github">GitHub URL</label>
                  <input id="site-github" name="github_url" type="url" />
                </div>
                <div class="admin-field">
                  <label for="site-linkedin">LinkedIn URL</label>
                  <input id="site-linkedin" name="linkedin_url" type="url" />
                </div>
                <div class="admin-field">
                  <label for="site-phone">Phone</label>
                  <input id="site-phone" name="phone" type="text" />
                </div>
                <div class="admin-field">
                  <label for="site-design">Design Variant</label>
                  <select id="site-design" name="design_variant">
                    <option value="command_center">Command Center</option>
                    <option value="clean_dossier">Clean Dossier</option>
                    <option value="terminal_ops">Terminal Ops</option>
                    <option value="signal_studio">Signal Studio</option>
                    <option value="system_forge">System Forge</option>
                  </select>
                </div>
                <div class="admin-field admin-field--full">
                  <label for="site-theme">Theme JSON</label>
                  <textarea id="site-theme" name="theme_json" spellcheck="false"></textarea>
                </div>
                <div class="admin-actions admin-field--full">
                  <button class="admin-button admin-button--primary" type="submit">Save site config</button>
                </div>
                <p class="admin-status admin-field--full" id="site-config-status"></p>
              </form>
            </div>
          </section>

          <section class="admin-card" data-panel="projects">
            <div class="admin-card__header">
              <div>
                <h3>Projects</h3>
                <p>Add, edit, publish, or remove portfolio projects.</p>
              </div>
              <button class="admin-button admin-button--primary" type="button" id="new-project-button">New project</button>
            </div>
            <div class="admin-card__body">
              <div class="admin-list" id="projects-list"></div>
              <div class="admin-empty admin-hidden" id="projects-empty">No projects loaded yet.</div>
            </div>
          </section>

          <section class="admin-card admin-hidden" data-panel="skills">
            <div class="admin-card__header">
              <div>
                <h3>Skills</h3>
                <p>Skill editor scaffold. Ready for the same CRUD pattern.</p>
              </div>
              <button class="admin-button admin-button--primary" type="button" id="new-skill-button">New skill</button>
            </div>
            <div class="admin-card__body">
              <div class="admin-list" id="skills-list"></div>
              <div class="admin-empty admin-hidden" id="skills-empty">No skills loaded yet.</div>
            </div>
          </section>

          <section class="admin-card admin-hidden" data-panel="experiments">
            <div class="admin-card__header">
              <div>
                <h3>Experiments</h3>
                <p>Teaching and community entries.</p>
              </div>
              <button class="admin-button admin-button--primary" type="button" id="new-experiment-button">New experiment</button>
            </div>
            <div class="admin-card__body">
              <div class="admin-list" id="experiments-list"></div>
              <div class="admin-empty admin-hidden" id="experiments-empty">No experiments loaded yet.</div>
            </div>
          </section>

          <section class="admin-card admin-hidden" data-panel="sections">
            <div class="admin-card__header">
              <div>
                <h3>Page Sections</h3>
                <p>Control custom content sections on the public site.</p>
              </div>
              <button class="admin-button admin-button--primary" type="button" id="new-section-button">New section</button>
            </div>
            <div class="admin-card__body">
              <div class="admin-list" id="sections-list"></div>
              <div class="admin-empty admin-hidden" id="sections-empty">No page sections loaded yet.</div>
            </div>
          </section>
        </div>
      </section>
    </div>
    <div class="admin-modal admin-hidden" id="project-modal" aria-hidden="true">
      <div class="admin-modal__backdrop" data-close-project-modal></div>
      <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
        <div class="admin-card__header">
          <div>
            <h3 id="project-modal-title">Project editor</h3>
            <p>Create or update a portfolio project.</p>
          </div>
          <button class="admin-button admin-button--ghost" type="button" data-close-project-modal>Close</button>
        </div>
        <div class="admin-card__body">
          <form class="admin-grid-form" id="project-form">
            <input type="hidden" id="project-id" name="id" />
            <div class="admin-field">
              <label for="project-title">Title</label>
              <input id="project-title" name="title" type="text" required />
            </div>
            <div class="admin-field">
              <label for="project-slug">Slug</label>
              <input id="project-slug" name="slug" type="text" required />
            </div>
            <div class="admin-field admin-field--full">
              <label for="project-description">Description</label>
              <textarea id="project-description" name="description" required></textarea>
            </div>
            <div class="admin-field admin-field--full">
              <label for="project-short-description">Short description</label>
              <textarea id="project-short-description" name="short_description"></textarea>
            </div>
            <div class="admin-field">
              <label for="project-role">Role</label>
              <input id="project-role" name="role" type="text" />
            </div>
            <div class="admin-field">
              <label for="project-impact">Impact</label>
              <input id="project-impact" name="impact" type="text" />
            </div>
            <div class="admin-field admin-field--full">
              <label for="project-image-url">Hero image URL</label>
              <input id="project-image-url" name="image_url" type="url" />
            </div>
            <div class="admin-field admin-field--full">
              <label for="project-tech-stack">Tech stack, comma separated</label>
              <input id="project-tech-stack" name="tech_stack" type="text" placeholder="Flutter, Dart, Supabase" required />
            </div>
            <div class="admin-field">
              <label for="project-display-order">Display order</label>
              <input id="project-display-order" name="display_order" type="number" min="0" step="1" />
            </div>
            <div class="admin-field">
              <label for="project-published">Published</label>
              <select id="project-published" name="is_published">
                <option value="false">Draft</option>
                <option value="true">Published</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="project-featured">Featured</label>
              <select id="project-featured" name="featured">
                <option value="false">No</option>
                <option value="true">Yes</option>
              </select>
            </div>
            <div class="admin-field admin-field--full">
              <label for="project-architecture">Architecture notes</label>
              <textarea id="project-architecture" name="architecture_notes"></textarea>
            </div>
            <div class="admin-field admin-field--full">
              <label for="project-case-study">Case study markdown</label>
              <textarea id="project-case-study" name="case_study_markdown"></textarea>
            </div>
            <div class="admin-field admin-field--full">
              <div class="admin-card__header" style="padding:0 0 10px;border:none;background:none;box-shadow:none;">
                <div>
                  <h3 style="margin:0;font-size:0.98rem;">Project Images</h3>
                  <p style="margin:4px 0 0;color:var(--admin-muted);">Manage gallery rows for the project.</p>
                </div>
                <button class="admin-button admin-button--ghost" type="button" id="project-image-add-button">Add image</button>
              </div>
              <div class="admin-list" id="project-images-list"></div>
              <div class="admin-empty admin-hidden" id="project-images-empty">No project images loaded yet.</div>
            </div>
            <div class="admin-actions admin-field--full">
              <button class="admin-button admin-button--primary" type="submit">Save project</button>
              <button class="admin-button admin-button--danger" type="button" id="project-delete-button">Delete project</button>
            </div>
            <p class="admin-status admin-field--full" id="project-form-status"></p>
          </form>
        </div>
      </div>
    </div>
    <div class="admin-modal admin-hidden" id="skill-modal" aria-hidden="true">
      <div class="admin-modal__backdrop" data-close-skill-modal></div>
      <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="skill-modal-title">
        <div class="admin-card__header">
          <div>
            <h3 id="skill-modal-title">Skill editor</h3>
            <p>Create or update a skill group.</p>
          </div>
          <button class="admin-button admin-button--ghost" type="button" data-close-skill-modal>Close</button>
        </div>
        <div class="admin-card__body">
          <form class="admin-grid-form" id="skill-form">
            <input type="hidden" id="skill-id" />
            <div class="admin-field admin-field--full">
              <label for="skill-category">Category</label>
              <input id="skill-category" type="text" required />
            </div>
            <div class="admin-field admin-field--full">
              <label for="skill-items">Items, comma separated</label>
              <input id="skill-items" type="text" required />
            </div>
            <div class="admin-field">
              <label for="skill-display-order">Display order</label>
              <input id="skill-display-order" type="number" min="0" step="1" />
            </div>
            <div class="admin-field">
              <label for="skill-published">Published</label>
              <select id="skill-published">
                <option value="false">Draft</option>
                <option value="true">Published</option>
              </select>
            </div>
            <div class="admin-actions admin-field--full">
              <button class="admin-button admin-button--primary" type="submit">Save skill</button>
              <button class="admin-button admin-button--danger" type="button" id="skill-delete-button">Delete skill</button>
            </div>
            <p class="admin-status admin-field--full" id="skill-form-status"></p>
          </form>
        </div>
      </div>
    </div>
    <div class="admin-modal admin-hidden" id="experiment-modal" aria-hidden="true">
      <div class="admin-modal__backdrop" data-close-experiment-modal></div>
      <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="experiment-modal-title">
        <div class="admin-card__header">
          <div>
            <h3 id="experiment-modal-title">Experiment editor</h3>
            <p>Create or update an experience entry.</p>
          </div>
          <button class="admin-button admin-button--ghost" type="button" data-close-experiment-modal>Close</button>
        </div>
        <div class="admin-card__body">
          <form class="admin-grid-form" id="experiment-form">
            <input type="hidden" id="experiment-id" />
            <div class="admin-field">
              <label for="experiment-title">Title</label>
              <input id="experiment-title" type="text" required />
            </div>
            <div class="admin-field">
              <label for="experiment-slug">Slug</label>
              <input id="experiment-slug" type="text" required />
            </div>
            <div class="admin-field">
              <label for="experiment-category">Category</label>
              <input id="experiment-category" type="text" required />
            </div>
            <div class="admin-field">
              <label for="experiment-status">Status</label>
              <select id="experiment-status">
                <option value="prototype">Prototype</option>
                <option value="active">Active</option>
                <option value="archived">Archived</option>
              </select>
            </div>
            <div class="admin-field admin-field--full">
              <label for="experiment-summary">Summary</label>
              <textarea id="experiment-summary" required></textarea>
            </div>
            <div class="admin-field">
              <label for="experiment-display-order">Display order</label>
              <input id="experiment-display-order" type="number" min="0" step="1" />
            </div>
            <div class="admin-field">
              <label for="experiment-published">Published</label>
              <select id="experiment-published">
                <option value="false">Draft</option>
                <option value="true">Published</option>
              </select>
            </div>
            <div class="admin-actions admin-field--full">
              <button class="admin-button admin-button--primary" type="submit">Save experiment</button>
              <button class="admin-button admin-button--danger" type="button" id="experiment-delete-button">Delete experiment</button>
            </div>
            <p class="admin-status admin-field--full" id="experiment-form-status"></p>
          </form>
        </div>
      </div>
    </div>
    <div class="admin-modal admin-hidden" id="section-modal" aria-hidden="true">
      <div class="admin-modal__backdrop" data-close-section-modal></div>
      <div class="admin-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="section-modal-title">
        <div class="admin-card__header">
          <div>
            <h3 id="section-modal-title">Page section editor</h3>
            <p>Create or update a public page section.</p>
          </div>
          <button class="admin-button admin-button--ghost" type="button" data-close-section-modal>Close</button>
        </div>
        <div class="admin-card__body">
          <form class="admin-grid-form" id="section-form">
            <input type="hidden" id="section-id" />
            <div class="admin-field">
              <label for="section-key">Section key</label>
              <input id="section-key" type="text" required />
            </div>
            <div class="admin-field">
              <label for="section-title">Title</label>
              <input id="section-title" type="text" required />
            </div>
            <div class="admin-field">
              <label for="section-eyebrow">Eyebrow</label>
              <input id="section-eyebrow" type="text" />
            </div>
            <div class="admin-field">
              <label for="section-placement">Placement</label>
              <select id="section-placement">
                <option value="after_hero">After hero</option>
                <option value="before_projects">Before projects</option>
                <option value="before_lab">Before lab</option>
                <option value="before_skills">Before skills</option>
                <option value="before_contact">Before contact</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="section-type">Section type</label>
              <select id="section-type">
                <option value="content_grid">Content grid</option>
                <option value="metric_strip">Metric strip</option>
                <option value="timeline">Timeline</option>
                <option value="callout">Callout</option>
                <option value="cta">CTA</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="section-layout">Layout</label>
              <select id="section-layout">
                <option value="stack">Stack</option>
                <option value="split">Split</option>
                <option value="grid">Grid</option>
                <option value="rail">Rail</option>
                <option value="banner">Banner</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="section-tone">Tone</label>
              <select id="section-tone">
                <option value="panel">Panel</option>
                <option value="ink">Ink</option>
                <option value="signal">Signal</option>
                <option value="studio">Studio</option>
                <option value="minimal">Minimal</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="section-density">Density</label>
              <select id="section-density">
                <option value="compact">Compact</option>
                <option value="standard">Standard</option>
                <option value="spacious">Spacious</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="section-alignment">Alignment</label>
              <select id="section-alignment">
                <option value="left">Left</option>
                <option value="center">Center</option>
              </select>
            </div>
            <div class="admin-field">
              <label for="section-display-order">Display order</label>
              <input id="section-display-order" type="number" min="0" step="1" />
            </div>
            <div class="admin-field">
              <label for="section-published">Published</label>
              <select id="section-published">
                <option value="false">Draft</option>
                <option value="true">Published</option>
              </select>
            </div>
            <div class="admin-field admin-field--full">
              <label for="section-body">Body</label>
              <textarea id="section-body"></textarea>
            </div>
            <div class="admin-field admin-field--full">
              <label for="section-content-json">Content JSON</label>
              <textarea id="section-content-json" spellcheck="false"></textarea>
            </div>
            <div class="admin-field admin-field--full">
              <label for="section-design-json">Design JSON</label>
              <textarea id="section-design-json" spellcheck="false"></textarea>
            </div>
            <div class="admin-actions admin-field--full">
              <button class="admin-button admin-button--primary" type="submit">Save section</button>
              <button class="admin-button admin-button--danger" type="button" id="section-delete-button">Delete section</button>
            </div>
            <p class="admin-status admin-field--full" id="section-form-status"></p>
          </form>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  const root = document.querySelector('[data-supabase-url]');
  const supabaseUrl = root?.dataset.supabaseUrl || '';
  const supabaseAnonKey = root?.dataset.supabaseAnonKey || '';
  const authStorageKey = 'portfolio-admin-session';

  const adminEmail = document.querySelector('#email');
  const adminPassword = document.querySelector('#password');
  const loginForm = document.querySelector('#login-form');
  const loginStatus = document.querySelector('#login-status');
  const appRoot = document.querySelector('#admin-app');
  const loginRoot = document.querySelector('#admin-login');
  const appStatus = document.querySelector('#app-status');
  const refreshButton = document.querySelector('#refresh-button');
  const publishButton = document.querySelector('#publish-button');
  const signoutButton = document.querySelector('#signout-button');
  const tabs = Array.from(document.querySelectorAll('[data-tab]'));
  const panels = Array.from(document.querySelectorAll('[data-panel]'));
  const siteConfigForm = document.querySelector('#site-config-form');
  const projectsList = document.querySelector('#projects-list');
  const projectsEmpty = document.querySelector('#projects-empty');
  const newProjectButton = document.querySelector('#new-project-button');
  const projectModal = document.querySelector('#project-modal');
  const projectForm = document.querySelector('#project-form');
  const projectFormStatus = document.querySelector('#project-form-status');
  const projectDeleteButton = document.querySelector('#project-delete-button');
  const closeProjectModalButtons = Array.from(document.querySelectorAll('[data-close-project-modal]'));
  const projectIdInput = document.querySelector('#project-id');
  const projectTitleInput = document.querySelector('#project-title');
  const projectSlugInput = document.querySelector('#project-slug');
  const projectDescriptionInput = document.querySelector('#project-description');
  const projectShortDescriptionInput = document.querySelector('#project-short-description');
  const projectRoleInput = document.querySelector('#project-role');
  const projectImpactInput = document.querySelector('#project-impact');
  const projectImageUrlInput = document.querySelector('#project-image-url');
  const projectTechStackInput = document.querySelector('#project-tech-stack');
  const projectDisplayOrderInput = document.querySelector('#project-display-order');
  const projectPublishedInput = document.querySelector('#project-published');
  const projectFeaturedInput = document.querySelector('#project-featured');
  const projectArchitectureInput = document.querySelector('#project-architecture');
  const projectCaseStudyInput = document.querySelector('#project-case-study');
  const projectImageAddButton = document.querySelector('#project-image-add-button');
  const projectImagesList = document.querySelector('#project-images-list');
  const projectImagesEmpty = document.querySelector('#project-images-empty');
  const siteConfigStatus = document.querySelector('#site-config-status');
  const skillsList = document.querySelector('#skills-list');
  const skillsEmpty = document.querySelector('#skills-empty');
  const newSkillButton = document.querySelector('#new-skill-button');
  const skillModal = document.querySelector('#skill-modal');
