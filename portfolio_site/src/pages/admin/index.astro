    if (projectRoleInput) projectRoleInput.value = '';
    if (projectImpactInput) projectImpactInput.value = '';
    if (projectImageUrlInput) projectImageUrlInput.value = '';
    if (projectTechStackInput) projectTechStackInput.value = 'Flutter, Dart, Supabase';
    if (projectDisplayOrderInput) projectDisplayOrderInput.value = String((state.projects?.length ?? 0) + 1);
    if (projectPublishedInput) projectPublishedInput.value = 'false';
    if (projectFeaturedInput) projectFeaturedInput.value = 'false';
    if (projectArchitectureInput) projectArchitectureInput.value = '';
