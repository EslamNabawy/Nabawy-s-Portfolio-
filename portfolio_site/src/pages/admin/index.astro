  const saveSkill = async () => {
    const items = String(skillItemsInput?.value ?? '')
      .split(',')
      .map((item) => item.trim())
      .filter(Boolean);
    if (!items.length) {
      setStatus(skillFormStatus, 'At least one skill item is required.', 'danger');
      return;
    }
    const payload = {
      category: String(skillCategoryInput?.value ?? '').trim(),
      items,
      display_order: Number(skillDisplayOrderInput?.value ?? 0),
      is_published: skillPublishedInput?.value === 'true',
    };
    try {
      if (skillIdInput?.value) {
        await api(`/rest/v1/skills?id=eq.${skillIdInput.value}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', Prefer: 'return=minimal' },
          body: JSON.stringify(payload),
        }, state.session);
        setStatus(skillFormStatus, 'Skill saved.', 'success');
      } else {
        await api('/rest/v1/skills', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Prefer: 'return=minimal' },
          body: JSON.stringify(payload),
        }, state.session);
        setStatus(skillFormStatus, 'Skill created.', 'success');
