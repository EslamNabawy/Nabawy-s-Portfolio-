    for (const project of projects) {
      const item = document.createElement('article');
      item.className = 'admin-item';
      item.innerHTML = `
        <div class="admin-item__top">
          <div>
            <h4 class="admin-item__title">${escapeHtml(project.title ?? '')}</h4>
            <div class="admin-item__meta">${escapeHtml(project.slug ?? '')}</div>
          </div>
