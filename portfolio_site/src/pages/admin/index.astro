  };

  const setActiveTab = (tabName) => {
    tabs.forEach((tab) => tab.setAttribute('aria-selected', String(tab.dataset.tab === tabName)));
    panels.forEach((panel) => panel.classList.toggle('admin-hidden', panel.dataset.panel !== tabName));
  };

  const parseMaybeJson = (value) => {
    if (!value || !value.trim()) return {};
    return JSON.parse(value);
  };

  const readFormObject = (form) => Object.fromEntries(new FormData(form).entries());

  const isTruthy = (value) => {
    const normalized = String(value ?? '').trim().toLowerCase();
    return normalized === 'true' || normalized === '1' || normalized === 'yes' || normalized === 'on';
  };

  const api = async (path, options = {}, session = null) => {
    const headers = new Headers(options.headers || {});
    headers.set('apikey', supabaseAnonKey);
    if (session?.access_token) {
      headers.set('Authorization', `Bearer ${session.access_token}`);
    }
    const response = await fetch(`${supabaseUrl}${path}`, { ...options, headers });
    const contentType = response.headers.get('content-type') || '';
    const body = contentType.includes('application/json') ? await response.json() : await response.text();
    if (!response.ok) {
      const message = body?.message || body?.error_description || body?.error || response.statusText;
      throw new Error(message);
    }
    return body;
  };

  const authRequest = async (email, password) => {
    const response = await fetch(`${supabaseUrl}/auth/v1/token?grant_type=password`, {
      method: 'POST',
      headers: {
        apikey: supabaseAnonKey,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ email, password }),
    });
    const body = await response.json();
    if (!response.ok) {
      throw new Error(body?.error_description || body?.msg || body?.message || 'Sign in failed');
    }
    return body;
  };

  const refreshData = async () => {
    setStatus(appStatus, 'Loading content...');
    try {
      const [siteConfigResult, projectsResult, skillsResult, experimentsResult, sectionsResult, publishLogResult, adminResult] = await Promise.all([
        api('/rest/v1/site_config?id=eq.global&select=*', {}, state.session),
        api('/rest/v1/projects?select=*,project_images(*)&order=featured.desc&order=display_order.asc', {}, state.session),
        api('/rest/v1/skills?select=*&order=display_order.asc', {}, state.session),
        api('/rest/v1/experiments?select=*&order=display_order.asc', {}, state.session),
        api('/rest/v1/page_sections?select=*&order=placement.asc&order=display_order.asc', {}, state.session),
        api('/rest/v1/publish_log?select=*&order=created_at.desc&limit=8', {}, state.session),
        api(`/rest/v1/admin_users?user_id=eq.${state.session?.user?.id ?? ''}&select=user_id`, {}, state.session),
      ]);

      if (!adminResult.length) {
        setStatus(appStatus, 'Authenticated, but not authorized as admin.', 'danger');
        return;
      }

      state.isAdmin = true;
      state.siteConfig = siteConfigResult[0];
      state.projects = projectsResult ?? [];
      state.skills = skillsResult ?? [];
      state.experiments = experimentsResult ?? [];
      state.sections = sectionsResult ?? [];
      state.publishLog = publishLogResult ?? [];
      hydrateSiteConfigForm(state.siteConfig);
      renderProjects(state.projects);
      renderSkills(state.skills);
      renderExperiments(state.experiments);
      renderSections(state.sections);
      renderPublishLog(state.publishLog);
      setStatus(publishLogStatus, `Showing ${state.publishLog.length} publish attempts.`);
      setStatus(appStatus, `Loaded ${state.projects.length} projects.`, 'success');
      showDashboard(true);
    } catch (error) {
      setStatus(appStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  };

