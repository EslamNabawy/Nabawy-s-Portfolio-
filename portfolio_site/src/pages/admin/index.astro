      'title',
      (item) => `${item.section_key ?? ''} · ${item.placement ?? ''} · ${item.section_type ?? ''}`,
      'edit-section',
      'delete-section',
    );
  };

  const renderPublishLog = (items) => {
    if (!publishLogList || !publishLogEmpty) return;
    publishLogList.innerHTML = '';
    publishLogEmpty.classList.toggle('admin-hidden', items.length > 0);

    for (const item of items) {
      const card = document.createElement('article');
      card.className = 'admin-item';
      card.innerHTML = `
        <div class="admin-item__top">
          <div>
            <h4 class="admin-item__title">${escapeHtml(item.status ?? '')}</h4>
            <div class="admin-item__meta">${escapeHtml(item.message ?? '')}</div>
          </div>
          <div class="admin-item__meta">${escapeHtml(item.updated_at ?? item.created_at ?? '')}</div>
        </div>
        <div class="admin-item__chips">
          <span class="admin-chip">${escapeHtml(item.triggered_by ?? 'unknown')}</span>
          ${item.workflow_run_url ? `<a class="admin-chip" href="${escapeHtml(item.workflow_run_url)}" target="_blank" rel="noopener noreferrer">Workflow</a>` : ''}
        </div>
      `;
      publishLogList.appendChild(card);
    }
  };

  const escapeHtml = (value) => String(value)
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');

  loginForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    setStatus(loginStatus, 'Signing in...');
    const email = adminEmail?.value?.trim() ?? '';
    const password = adminPassword?.value ?? '';

    try {
      const data = await authRequest(email, password);
      state.session = data;
      localStorage.setItem(authStorageKey, JSON.stringify(data));
      await refreshData();
    } catch (error) {
      setStatus(loginStatus, error.message, 'danger');
    }
  });

  refreshButton?.addEventListener('click', refreshData);
  publishButton?.addEventListener('click', async () => {
    if (!state.session?.access_token) {
      setStatus(appStatus, 'Sign in first.', 'danger');
      return;
    }
    setStatus(appStatus, 'Triggering publish...');
    try {
      const response = await fetch(`${supabaseUrl}/functions/v1/publish-portfolio`, {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${state.session.access_token}`,
          apikey: supabaseAnonKey,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({}),
      });
      const body = await response.json();
      if (!response.ok) {
        throw new Error(body?.error || body?.message || response.statusText);
      }
      setStatus(appStatus, body.message || 'Publish triggered.', 'success');
      await refreshData();
    } catch (error) {
      setStatus(appStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  });
  signoutButton?.addEventListener('click', async () => {
    localStorage.removeItem(authStorageKey);
    state.session = null;
    state.isAdmin = false;
    showDashboard(false);
    setStatus(loginStatus, 'Signed out.', 'success');
  });

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => setActiveTab(tab.dataset.tab ?? 'site-config'));
  });

  siteConfigForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!state.isAdmin) {
      setStatus(siteConfigStatus, 'Sign in as an admin first.', 'danger');
      return;
    }

    const form = readFormObject(siteConfigForm);
    const payload = {
      name: String(form.name ?? '').trim(),
      headline: String(form.headline ?? '').trim(),
      bio: String(form.bio ?? '').trim(),
      resume_url: String(form.resume_url ?? '').trim() || null,
      email: String(form.email ?? '').trim() || null,
      github_url: String(form.github_url ?? '').trim() || null,
      linkedin_url: String(form.linkedin_url ?? '').trim() || null,
      phone: String(form.phone ?? '').trim() || null,
      design_variant: String(form.design_variant ?? 'command_center'),
      theme_json: parseMaybeJson(String(form.theme_json ?? '{}')),
    };

    setStatus(siteConfigStatus, 'Saving site config...');
    try {
      await api('/rest/v1/site_config?id=eq.global', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          Prefer: 'return=minimal',
        },
        body: JSON.stringify(payload),
      }, state.session);
      setStatus(siteConfigStatus, 'Site config saved.', 'success');
    } catch (error) {
      setStatus(siteConfigStatus, error.message, 'danger');
    }
  });

  newProjectButton?.addEventListener('click', async () => {
    openProjectForm();
  });

  newSkillButton?.addEventListener('click', async () => {
    openSkillForm();
  });

  newExperimentButton?.addEventListener('click', async () => {
    openExperimentForm();
  });

  newSectionButton?.addEventListener('click', async () => {
    openSectionForm();
  });

  document.addEventListener('click', async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    if (target.matches('[data-close-project-modal]')) {
      closeProjectForm();
      return;
    }

    const editId = target.dataset.editProject;
    const deleteId = target.dataset.deleteProject;

    if (editId) {
      const project = state.projects.find((item) => item.id === editId);
      if (!project) return;
      openProjectForm(project);
      return;
    }

    if (deleteId) {
      if (!window.confirm('Delete this project?')) return;
      try {
        await api(`/rest/v1/projects?id=eq.${deleteId}`, {
          method: 'DELETE',
          headers: { Prefer: 'return=minimal' },
        }, state.session);
        await refreshData();
        setStatus(appStatus, 'Project deleted.', 'success');
      } catch (error) {
        setStatus(appStatus, error.message, 'danger');
      }
      return;
    }

    const editSkillId = target.dataset.editSkill;
    const deleteSkillId = target.dataset.deleteSkill;
    if (editSkillId) {
      const skill = state.skills.find((item) => item.id === editSkillId);
      if (!skill) return;
      openSkillForm(skill);
      return;
    }
    if (deleteSkillId) {
      if (!window.confirm('Delete this skill?')) return;
      try {
        await api(`/rest/v1/skills?id=eq.${deleteSkillId}`, { method: 'DELETE', headers: { Prefer: 'return=minimal' } }, state.session);
        await refreshData();
        setStatus(appStatus, 'Skill deleted.', 'success');
      } catch (error) {
        setStatus(appStatus, error.message, 'danger');
      }
      return;
    }

    const editExperimentId = target.dataset.editExperiment;
    const deleteExperimentId = target.dataset.deleteExperiment;
    if (editExperimentId) {
      const experiment = state.experiments.find((item) => item.id === editExperimentId);
      if (!experiment) return;
      openExperimentForm(experiment);
      return;
    }
    if (deleteExperimentId) {
      if (!window.confirm('Delete this experiment?')) return;
      try {
        await api(`/rest/v1/experiments?id=eq.${deleteExperimentId}`, { method: 'DELETE', headers: { Prefer: 'return=minimal' } }, state.session);
        await refreshData();
        setStatus(appStatus, 'Experiment deleted.', 'success');
      } catch (error) {
        setStatus(appStatus, error.message, 'danger');
      }
      return;
    }

    const editSectionId = target.dataset.editSection;
    const deleteSectionId = target.dataset.deleteSection;
    if (editSectionId) {
      const section = state.sections.find((item) => item.id === editSectionId);
      if (!section) return;
      openSectionForm(section);
      return;
    }
    if (deleteSectionId) {
      if (!window.confirm('Delete this page section?')) return;
      try {
        await api(`/rest/v1/page_sections?id=eq.${deleteSectionId}`, { method: 'DELETE', headers: { Prefer: 'return=minimal' } }, state.session);
        await refreshData();
        setStatus(appStatus, 'Section deleted.', 'success');
      } catch (error) {
        setStatus(appStatus, error.message, 'danger');
      }
      return;
    }

    const editProjectImageId = target.dataset.editProjectImage;
    const deleteProjectImageId = target.dataset.deleteProjectImage;
    if (editProjectImageId) {
      const image = state.projectImages.find((item) => item.id === editProjectImageId);
      if (!image) return;
      try {
        await api(`/rest/v1/project_images?id=eq.${editProjectImageId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', Prefer: 'return=minimal' },
          body: JSON.stringify({
            image_url: window.prompt('Image URL', image.image_url ?? '') ?? image.image_url,
            alt_text: window.prompt('Alt text', image.alt_text ?? '') || null,
            display_order: Number(window.prompt('Display order', String(image.display_order ?? 0)) ?? image.display_order ?? 0),
          }),
        }, state.session);
        await loadProjectImages(projectIdInput?.value ?? '');
        setStatus(projectFormStatus, 'Project image saved.', 'success');
      } catch (error) {
        setStatus(projectFormStatus, error instanceof Error ? error.message : String(error), 'danger');
      }
      return;
    }
    if (deleteProjectImageId) {
      if (!window.confirm('Delete this project image?')) return;
      try {
        await api(`/rest/v1/project_images?id=eq.${deleteProjectImageId}`, {
          method: 'DELETE',
          headers: { Prefer: 'return=minimal' },
        }, state.session);
        await loadProjectImages(projectIdInput?.value ?? '');
        setStatus(projectFormStatus, 'Project image deleted.', 'success');
      } catch (error) {
        setStatus(projectFormStatus, error instanceof Error ? error.message : String(error), 'danger');
      }
      return;
    }
  });

  skillForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    await saveSkill();
  });

  skillDeleteButton?.addEventListener('click', async () => {
    if (!skillIdInput?.value) return;
    if (!window.confirm('Delete this skill?')) return;
    try {
      await api(`/rest/v1/skills?id=eq.${skillIdInput.value}`, { method: 'DELETE', headers: { Prefer: 'return=minimal' } }, state.session);
      await refreshData();
      closeSkillForm();
      setStatus(appStatus, 'Skill deleted.', 'success');
    } catch (error) {
      setStatus(skillFormStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  });

  closeSkillModalButtons.forEach((button) => button.addEventListener('click', closeSkillForm));

  experimentForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    await saveExperiment();
  });

  experimentDeleteButton?.addEventListener('click', async () => {
    if (!experimentIdInput?.value) return;
    if (!window.confirm('Delete this experiment?')) return;
    try {
      await api(`/rest/v1/experiments?id=eq.${experimentIdInput.value}`, { method: 'DELETE', headers: { Prefer: 'return=minimal' } }, state.session);
      await refreshData();
      closeExperimentForm();
      setStatus(appStatus, 'Experiment deleted.', 'success');
    } catch (error) {
      setStatus(experimentFormStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  });

  closeExperimentModalButtons.forEach((button) => button.addEventListener('click', closeExperimentForm));

  sectionForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    await saveSection();
  });

  sectionDeleteButton?.addEventListener('click', async () => {
    if (!sectionIdInput?.value) return;
    if (!window.confirm('Delete this page section?')) return;
    try {
      await api(`/rest/v1/page_sections?id=eq.${sectionIdInput.value}`, { method: 'DELETE', headers: { Prefer: 'return=minimal' } }, state.session);
      await refreshData();
      closeSectionForm();
      setStatus(appStatus, 'Section deleted.', 'success');
    } catch (error) {
      setStatus(sectionFormStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  });

  closeSectionModalButtons.forEach((button) => button.addEventListener('click', closeSectionForm));

  projectForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!state.isAdmin) {
      setStatus(projectFormStatus, 'Sign in as an admin first.', 'danger');
      return;
    }

    const techStackItems = String(projectTechStackInput?.value ?? '')
      .split(',')
      .map((item) => item.trim())
      .filter(Boolean);
    if (techStackItems.length === 0) {
      setStatus(projectFormStatus, 'Tech stack is required.', 'danger');
      return;
    }

    const payload = {
      title: String(projectTitleInput?.value ?? '').trim(),
      slug: String(projectSlugInput?.value ?? '').trim(),
      description: String(projectDescriptionInput?.value ?? '').trim(),
      short_description: String(projectShortDescriptionInput?.value ?? '').trim() || null,
      role: String(projectRoleInput?.value ?? '').trim() || null,
      impact: String(projectImpactInput?.value ?? '').trim() || null,
      architecture_notes: String(projectArchitectureInput?.value ?? '').trim() || null,
      case_study_markdown: String(projectCaseStudyInput?.value ?? '').trim() || null,
      tech_stack: techStackItems,
      image_url: String(projectImageUrlInput?.value ?? '').trim() || null,
      is_published: projectPublishedInput?.value === 'true',
      featured: projectFeaturedInput?.value === 'true',
      display_order: Number(projectDisplayOrderInput?.value ?? 0),
    };

    try {
      if (projectIdInput?.value) {
        await api(`/rest/v1/projects?id=eq.${projectIdInput.value}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', Prefer: 'return=minimal' },
          body: JSON.stringify(payload),
        }, state.session);
        setStatus(projectFormStatus, 'Project saved.', 'success');
      } else {
        await api('/rest/v1/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Prefer: 'return=minimal' },
          body: JSON.stringify({
            ...payload,
            github_url: null,
            live_url: null,
            is_published: false,
            featured: false,
          }),
        }, state.session);
        setStatus(projectFormStatus, 'Project created.', 'success');
      }
      await refreshData();
      closeProjectForm();
    } catch (error) {
      setStatus(projectFormStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  });

  projectDeleteButton?.addEventListener('click', async () => {
    if (!projectIdInput?.value) return;
    if (!window.confirm('Delete this project?')) return;
    try {
      await api(`/rest/v1/projects?id=eq.${projectIdInput.value}`, {
        method: 'DELETE',
        headers: { Prefer: 'return=minimal' },
      }, state.session);
      await refreshData();
      closeProjectForm();
      setStatus(appStatus, 'Project deleted.', 'success');
    } catch (error) {
      setStatus(projectFormStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  });

  projectImageAddButton?.addEventListener('click', async () => {
    const projectId = projectIdInput?.value;
    if (!projectId) {
      setStatus(projectFormStatus, 'Save the project before adding images.', 'danger');
      return;
    }
    const image_url = window.prompt('Image URL');
    if (!image_url) return;
    const alt_text = window.prompt('Alt text') ?? '';
    const display_order = Number(window.prompt('Display order', String((state.projectImages?.length ?? 0) + 1)) ?? (state.projectImages?.length ?? 0) + 1);
    try {
      await api('/rest/v1/project_images', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Prefer: 'return=minimal' },
        body: JSON.stringify({
          project_id: projectId,
          image_url,
          alt_text: alt_text || null,
          display_order,
        }),
      }, state.session);
      await loadProjectImages(projectId);
      setStatus(projectFormStatus, 'Project image added.', 'success');
    } catch (error) {
      setStatus(projectFormStatus, error instanceof Error ? error.message : String(error), 'danger');
    }
  });

  closeProjectModalButtons.forEach((button) => button.addEventListener('click', closeProjectForm));

  const storedSession = (() => {
    try {
      return JSON.parse(localStorage.getItem(authStorageKey) || 'null');
    } catch {
      return null;
    }
  })();

  if (storedSession?.access_token) {
    state.session = storedSession;
    refreshData().catch(() => showDashboard(false));
  } else {
    showDashboard(false);
  }

  setActiveTab('site-config');
</script>
