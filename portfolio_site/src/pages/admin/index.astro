  const setStatus = (node, message, tone = '') => {
    if (!node) return;
    node.textContent = message;
    if (tone) node.dataset.tone = tone;
    else delete node.dataset.tone;
  };

  const showDashboard = (show) => {
    loginRoot?.classList.toggle('admin-hidden', show);
    appRoot?.classList.toggle('admin-hidden', !show);
  };

  const showProjectModal = (show) => {
    projectModal?.classList.toggle('admin-hidden', !show);
    if (projectModal) {
      projectModal.setAttribute('aria-hidden', String(!show));
    }
  };

  const showSkillModal = (show) => {
    skillModal?.classList.toggle('admin-hidden', !show);
    if (skillModal) skillModal.setAttribute('aria-hidden', String(!show));
  };

