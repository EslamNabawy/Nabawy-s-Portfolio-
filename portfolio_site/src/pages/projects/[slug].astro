---
import SkillBadge from '../../components/SkillBadge.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjectHeroImage, getPublishedProjects } from '../../lib/portfolio-data';
import type { Project } from '../../lib/types';

export async function getStaticPaths() {
  const projects = await getPublishedProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const heroImage = getProjectHeroImage(project);
const galleryImages = (project.project_images ?? []).filter(
  (image) => image.image_url !== heroImage,
);
const summary = project.short_description ?? project.description;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={`${project.title} | Project`} description={summary}>
  <main class="min-h-screen bg-panel">
    <section class="border-b border-line bg-white px-6 py-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <nav class="mb-8 flex flex-wrap items-center justify-between gap-4 border-b border-line pb-4">
          <a class="font-mono text-sm font-black uppercase tracking-[0.16em] text-signal" href={base}>
            Back To Portfolio
          </a>
          <span class="font-mono text-xs font-black uppercase tracking-[0.16em] text-quiet">
            {project.featured ? 'Featured Project' : 'Project'}
          </span>
        </nav>

        <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
          <div class="min-w-0">
            <p class="mb-4 font-mono text-xs font-black uppercase tracking-[0.18em] text-alert">
              {project.slug}
            </p>
            <h1 class="break-words text-4xl font-black leading-[0.98] text-ink sm:text-7xl">
              {project.title}
            </h1>
            <p class="mt-5 max-w-3xl whitespace-pre-line text-lg leading-8 text-quiet">
              {summary}
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              {project.github_url && (
                <a class="border border-ink bg-ink px-4 py-2 text-sm font-bold text-white" href={project.github_url}>
                  Source
                </a>
              )}
              {project.live_url && (
                <a class="border border-line bg-white px-4 py-2 text-sm font-bold text-ink" href={project.live_url}>
                  Live Build
                </a>
              )}
            </div>
          </div>

          <aside class="min-w-0 border border-line bg-panel p-4">
            <img
              src={heroImage}
              alt={`${project.title} interface preview`}
              class="aspect-[16/10] w-full border border-line bg-white object-cover"
            />
            <div class="mt-4 flex flex-wrap gap-2">
              {project.tech_stack.map((item) => <SkillBadge label={item} />)}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="border-b border-line px-6 py-12 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-3">
        <article class="border border-line bg-white p-5">
          <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-quiet">Role</p>
          <p class="mt-3 text-lg font-black text-ink">{project.role ?? 'Builder / Engineer'}</p>
        </article>
        <article class="border border-line bg-white p-5">
          <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-quiet">Impact</p>
          <p class="mt-3 text-lg font-black text-ink">{project.impact ?? 'Delivered project'}</p>
        </article>
        <article class="border border-line bg-white p-5">
          <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-quiet">Stack</p>
          <p class="mt-3 text-lg font-black text-ink">{project.tech_stack.length} technologies</p>
        </article>
      </div>
    </section>

    <section class="px-6 py-12 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[0.88fr_1.12fr]">
        <aside class="border border-line bg-white p-5">
          <h2 class="text-2xl font-black text-ink">Project Details</h2>
          <dl class="mt-6 grid gap-4">
            <div class="border-b border-line pb-4">
              <dt class="font-mono text-xs font-black uppercase tracking-[0.14em] text-quiet">Status</dt>
              <dd class="mt-1 text-sm font-bold text-signal">Published</dd>
            </div>
            <div class="border-b border-line pb-4">
              <dt class="font-mono text-xs font-black uppercase tracking-[0.14em] text-quiet">Priority</dt>
              <dd class="mt-1 text-sm font-bold text-ink">#{project.display_order}</dd>
            </div>
            <div>
              <dt class="font-mono text-xs font-black uppercase tracking-[0.14em] text-quiet">Updated</dt>
              <dd class="mt-1 text-sm font-bold text-ink">
                {project.updated_at ? new Date(project.updated_at).toLocaleDateString('en-US') : 'Not recorded'}
              </dd>
            </div>
          </dl>
        </aside>

        <article class="border border-line bg-white p-6">
          <h2 class="text-3xl font-black text-ink">What I Built</h2>
          <p class="mt-5 whitespace-pre-line text-base leading-8 text-quiet">
            {project.description}
          </p>
          {project.architecture_notes && (
            <section class="mt-8 border-t border-line pt-6">
              <h3 class="font-mono text-sm font-black uppercase tracking-[0.16em] text-signal">
                Architecture
              </h3>
              <p class="mt-3 whitespace-pre-line text-base leading-8 text-quiet">
                {project.architecture_notes}
              </p>
            </section>
          )}
          {project.case_study_markdown && (
            <section class="mt-8 border-t border-line pt-6">
              <h3 class="font-mono text-sm font-black uppercase tracking-[0.16em] text-signal">
                Summary
              </h3>
              <p class="mt-3 whitespace-pre-line text-base leading-8 text-quiet">
                {project.case_study_markdown}
              </p>
            </section>
          )}
        </article>
      </div>
    </section>

    {galleryImages.length > 0 && (
      <section class="border-t border-line bg-white px-6 py-12 lg:px-8">
        <div class="mx-auto max-w-7xl">
          <h2 class="text-3xl font-black text-ink">Evidence Gallery</h2>
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {galleryImages.map((image) => (
              <img
                src={image.image_url}
                alt={image.alt_text ?? `${project.title} supporting screenshot`}
                loading="lazy"
                class="aspect-[16/10] w-full border border-line bg-panel object-cover"
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
