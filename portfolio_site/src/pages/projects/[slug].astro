---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPortfolioData, getProjectHeroImage } from '../../lib/portfolio-data';
import type { Project, SiteConfig } from '../../lib/types';
import '../../styles/project-detail.css';

type DetailItem = {
  title: string;
  description: string;
};

type ArchitectureLayer = {
  name: string;
  items: string[];
};

type ProjectDetailContent = {
  category: string;
  subtitle: string;
  type: string;
  platform: string;
  timeline: string;
  status: string;
  highlights: DetailItem[];
  decisions: DetailItem[];
  layers: ArchitectureLayer[];
};

