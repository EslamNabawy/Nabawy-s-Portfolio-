export async function getStaticPaths() {
  const { config, projects } = await getPortfolioData();
  const preferredProjectOrder = [
    'brox',
    'rain-p2p-messenger',
    'campus-suit',
    'silvator',
    'ai-workflow-automation',
    'so-she-picks-ecommerce',
  ];
  const orderedProjects = [...projects].sort((left, right) => {
    const leftIndex = preferredProjectOrder.indexOf(left.slug);
    const rightIndex = preferredProjectOrder.indexOf(right.slug);
    const normalizedLeft = leftIndex === -1 ? Number.MAX_SAFE_INTEGER : leftIndex;
    const normalizedRight = rightIndex === -1 ? Number.MAX_SAFE_INTEGER : rightIndex;
    if (normalizedLeft !== normalizedRight) {
      return normalizedLeft - normalizedRight;
    }
    return left.display_order - right.display_order;
  });

  return orderedProjects.map((project, index) => ({
    params: { slug: project.slug },
    props: {
      config,
      nextProject: orderedProjects[(index + 1) % orderedProjects.length],
      project,
    },
  }));
}

interface Props {
  config: SiteConfig;
  nextProject: Project;
  project: Project;
}

const { config, nextProject, project } = Astro.props as Props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const heroImage = getProjectHeroImage(project);
const allImages = project.project_images ?? [];
const heroAlt =
  allImages.find((image) => image.image_url === heroImage)?.alt_text ??
  `${project.title} project preview`;
const primaryScreen = allImages.find((image) => image.image_url !== heroImage) ?? allImages[0] ?? null;
const thumbImages = primaryScreen
  ? allImages.filter((image) => image.id !== primaryScreen.id)
  : allImages;
const summary = project.short_description ?? project.description;
const content = projectDetails[project.slug] ?? {
  category: 'Software Project',
  subtitle: summary,
  type: 'Software',
  platform: 'Cross-platform',
  timeline: 'Current build',
  status: project.is_published ? 'Published case study' : 'Draft',
  highlights: [
    { title: 'Product scope', description: summary },
    { title: 'Engineering role', description: project.role ?? 'Built as a software engineering project.' },
    { title: 'Impact', description: project.impact ?? 'Delivered a focused working product experience.' },
  ],
  decisions: [
    {
      title: 'Implementation focus',
      description: project.architecture_notes ?? project.description,
    },
  ],
  layers: [{ name: 'Stack', items: project.tech_stack }],
};

const displayDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  year: 'numeric',
});
const updatedLabel = project.updated_at ? displayDate.format(new Date(project.updated_at)) : 'Current';
const nextHref = `${base}projects/${nextProject.slug}/`;
const nextSummary = nextProject.short_description ?? nextProject.description;
const phoneHref = config.phone ? `tel:${config.phone.replace(/[^\d+]/g, '')}` : null;
const contactLinks = [
  { label: config.email, href: config.email ? `mailto:${config.email}` : null, text: 'Email' },
  { label: 'GitHub', href: config.github_url, text: 'GitHub' },
  { label: 'LinkedIn', href: config.linkedin_url, text: 'LinkedIn' },
  { label: config.phone, href: phoneHref, text: 'Phone' },
].filter((item) => item.href && item.label) as { label: string; href: string; text: string }[];
const hotStack = new Set(['Flutter', 'Dart', 'Flutter Desktop', 'Riverpod', 'WebRTC', 'n8n', 'OpenAI API', 'Claude API', 'Cubit/Bloc', 'BLoC']);
---

<BaseLayout title={`${project.title} | Project`} description={summary}>
  <main class="pd-project">
    <canvas id="pd-bg-canvas" aria-hidden="true"></canvas>
    <div class="pd-progress" id="pd-progress" aria-hidden="true"></div>

    <nav class="pd-nav" aria-label="Project navigation">
      <a class="pd-nav-logo" href={base}>eslam<em>.dev</em></a>
      <a class="pd-nav-back" href={`${base}#projects`} aria-label="Back to all projects">
        <span aria-hidden="true">&larr;</span>
        All Projects
      </a>
      <a class="pd-nav-hire" href="#contact-section">Hire Me</a>
    </nav>

    <section class="pd-hero" id="project-hero">
      <div class:list={['pd-hero-media', `pd-tint-${project.slug}`]}>
        {heroImage && <img src={heroImage} alt={heroAlt} loading="eager" />}
      </div>
      <div class="pd-hero-overlay"></div>

      <div class="pd-hero-content">
        <p class="pd-eyebrow pd-reveal"><span></span>{content.category}</p>
        <h1 class="pd-title pd-reveal">{project.title}</h1>
        <p class="pd-subtitle pd-reveal">{content.subtitle}</p>

        <div class="pd-meta-row pd-reveal">
          <span class="pd-tag">{content.platform}</span>
          <span class="pd-dot"></span>
          <span>{updatedLabel}</span>
          <span class="pd-dot"></span>
          <span>{project.featured ? 'Featured project' : 'Project case study'}</span>
        </div>

        <div class="pd-ctas pd-reveal">
          {project.github_url && (
            <a class="pd-btn pd-btn-fill" href={project.github_url} target="_blank" rel="noreferrer">
              Source
            </a>
          )}
          {project.live_url && (
            <a class="pd-btn pd-btn-fill" href={project.live_url} target="_blank" rel="noreferrer">
              Live Build
            </a>
          )}
          {allImages.length > 0 && <a class="pd-btn pd-btn-line" href="#screens">Screenshots</a>}
          <a class="pd-btn pd-btn-line" href="#details">Details</a>
        </div>

        <div class="pd-facts pd-reveal" aria-label="Project quick facts">
          <div>
            <span>Role</span>
            <strong>{project.role ?? 'Software Engineer'}</strong>
          </div>
          <div>
            <span>Type</span>
            <strong>{content.type}</strong>
          </div>
          <div>
            <span>Media</span>
            <strong>{allImages.length} screenshots</strong>
          </div>
        </div>
      </div>
    </section>

    <div class="pd-body" id="details">
      <div class="pd-main-col">
        <section class="pd-section" id="overview">
          <p class="pd-section-tag pd-reveal">Overview</p>
          <h2 class="pd-section-title pd-reveal">What I built</h2>
          <p class="pd-overview pd-reveal">{project.description}</p>
          {project.impact && <p class="pd-overview pd-reveal">{project.impact}</p>}
          {project.case_study_markdown && <p class="pd-overview pd-reveal">{project.case_study_markdown}</p>}
        </section>

        {allImages.length > 0 && (
          <section class="pd-section pd-screens-section" id="screens">
            <p class="pd-section-tag pd-reveal">Screens</p>
            <h2 class="pd-section-title pd-reveal">Product screenshots</h2>

            {primaryScreen && (
              <button
                class="pd-screen-primary pd-reveal"
                type="button"
                data-full={primaryScreen.image_url}
                data-alt={primaryScreen.alt_text ?? `${project.title} primary screenshot`}
              >
                <img
                  src={primaryScreen.image_url}
                  alt={primaryScreen.alt_text ?? `${project.title} primary screenshot`}
                  loading="eager"
                />
                <span>{primaryScreen.alt_text ?? `${project.title} screen`}</span>
              </button>
            )}

            {thumbImages.length > 0 && (
              <div class="pd-screens-grid pd-reveal">
                {thumbImages.map((image, index) => (
                  <button
                    class="pd-screen-thumb"
                    type="button"
                    data-full={image.image_url}
                    data-alt={image.alt_text ?? `${project.title} screenshot ${index + 1}`}
                  >
                    <img
                      src={image.image_url}
                      alt={image.alt_text ?? `${project.title} screenshot ${index + 1}`}
                      loading="lazy"
                    />
                    <span>{String(index + 1).padStart(2, '0')}</span>
                  </button>
                ))}
              </div>
            )}
          </section>
        )}

        <section class="pd-section" id="highlights">
          <p class="pd-section-tag pd-reveal">Highlights</p>
          <h2 class="pd-section-title pd-reveal">What makes it notable</h2>
          <div class="pd-highlight-list">
            {content.highlights.map((item) => (
              <article class="pd-highlight pd-reveal">
                <span aria-hidden="true"></span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="pd-section" id="engineering">
          <p class="pd-section-tag pd-reveal">Engineering</p>
          <h2 class="pd-section-title pd-reveal">Decisions and constraints</h2>
          <div class="pd-decision-list">
            {content.decisions.map((item, index) => (
              <article class="pd-decision pd-reveal">
                <small>Decision {String(index + 1).padStart(2, '0')}</small>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="pd-section" id="architecture">
          <p class="pd-section-tag pd-reveal">Architecture</p>
          <h2 class="pd-section-title pd-reveal">How it is structured</h2>
          <div class="pd-architecture pd-reveal">
            {content.layers.map((layer) => (
              <div class="pd-arch-row">
                <span>{layer.name}</span>
                <div>
                  {layer.items.map((item) => <em>{item}</em>)}
                </div>
              </div>
            ))}
          </div>
          {project.architecture_notes && (
            <p class="pd-architecture-note pd-reveal">{project.architecture_notes}</p>
          )}
        </section>
      </div>

      <aside class="pd-sidebar" aria-label="Project sidebar">
        <div class="pd-sidebar-card pd-reveal-r">
          <p class="pd-sidebar-label">Jump to</p>
          <div class="pd-side-nav">
            <a href="#overview" class="active">Overview</a>
            {allImages.length > 0 && <a href="#screens">Screenshots</a>}
            <a href="#highlights">Highlights</a>
            <a href="#engineering">Engineering</a>
            <a href="#architecture">Architecture</a>
          </div>
        </div>

        <div class="pd-sidebar-card pd-reveal-r">
          <p class="pd-sidebar-label">Project info</p>
          <dl class="pd-info-list">
            <div>
              <dt>Type</dt>
              <dd>{content.type}</dd>
            </div>
            <div>
              <dt>Platform</dt>
              <dd>{content.platform}</dd>
            </div>
            <div>
              <dt>Timeline</dt>
              <dd>{content.timeline}</dd>
            </div>
            <div>
              <dt>Role</dt>
              <dd>{project.role ?? 'Software Engineer'}</dd>
            </div>
            <div>
              <dt>Status</dt>
              <dd>{content.status}</dd>
            </div>
            <div>
              <dt>Updated</dt>
              <dd>{updatedLabel}</dd>
            </div>
          </dl>
        </div>

        <div class="pd-sidebar-card pd-reveal-r">
          <p class="pd-sidebar-label">Tech stack</p>
          <div class="pd-stack">
            {project.tech_stack.map((item) => (
              <span class:list={['pd-stack-tag', hotStack.has(item) && 'is-hot']}>{item}</span>
            ))}
          </div>
        </div>

        <div class="pd-sidebar-card pd-sidebar-cta pd-reveal-r">
          <p>Interested in similar work?</p>
          {config.email && <a class="pd-btn pd-btn-fill" href={`mailto:${config.email}`}>Get in Touch</a>}
          <a class="pd-btn pd-btn-line" href={base}>Back to Portfolio</a>
        </div>
      </aside>
    </div>

    <section class="pd-next-project" id="next-project">
      <div>
        <p>Next project</p>
        <h2>{nextProject.title}</h2>
        <span>{nextSummary}</span>
      </div>
      <a href={nextHref} aria-label={`Open ${nextProject.title}`}>&rarr;</a>
    </section>

    <section class="pd-contact" id="contact-section">
      <div class="pd-contact-glow"></div>
      <div class="pd-contact-inner">
        <h2 class="pd-reveal">Let's build <em>something useful</em></h2>
        <p class="pd-reveal">Open to software engineering roles, freelance builds, and practical product collaborations.</p>
        <div class="pd-contact-links pd-reveal">
          {contactLinks.map((item) => (
            <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
              <span>{item.text}</span>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <footer class="pd-footer">
      <p>&copy; 2026 <em>Eslam Tarek Nabawy</em></p>
      <p>Software Engineer &middot; Egypt &middot; <em>Built with intent</em></p>
    </footer>

    <div class="pd-lightbox" id="pd-lightbox" hidden>
      <button class="pd-lightbox-close" type="button" aria-label="Close screenshot">Close</button>
      {heroImage && <img src={heroImage} alt={heroAlt} />}
    </div>
  </main>
</BaseLayout>

<script>
  const progress = document.getElementById('pd-progress');
  const updateProgress = () => {
    if (!progress) return;
    const max = document.documentElement.scrollHeight - window.innerHeight;
    progress.style.width = `${max > 0 ? (window.scrollY / max) * 100 : 0}%`;
  };
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  const canvas = document.getElementById('pd-bg-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const context = canvas.getContext('2d');
    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    const particles = Array.from({ length: 64 }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      vx: (Math.random() - 0.5) * 0.22,
      vy: (Math.random() - 0.5) * 0.22,
      r: Math.random() * 1.3 + 0.5,
    }));
    const draw = () => {
      if (!context) return;
      context.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach((particle) => {
        particle.x += particle.vx;
        particle.y += particle.vy;
        if (particle.x < 0) particle.x = canvas.width;
        if (particle.x > canvas.width) particle.x = 0;
        if (particle.y < 0) particle.y = canvas.height;
        if (particle.y > canvas.height) particle.y = 0;
        context.beginPath();
        context.arc(particle.x, particle.y, particle.r, 0, Math.PI * 2);
        context.fillStyle = 'rgba(0,255,200,.58)';
        context.fill();
      });
      requestAnimationFrame(draw);
    };
    resize();
    window.addEventListener('resize', resize);
    draw();
  }

  const revealElements = document.querySelectorAll('.pd-reveal,.pd-reveal-r');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (!entry.isIntersecting) return;
        window.setTimeout(() => entry.target.classList.add('is-on'), index * 45);
        revealObserver.unobserve(entry.target);
      });
    },
    { threshold: 0.1 },
  );
  revealElements.forEach((element) => revealObserver.observe(element));

  const sideLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.pd-side-nav a'));
  const observedSections = sideLinks
    .map((link) => document.querySelector(link.getAttribute('href') ?? ''))
    .filter((section): section is Element => section instanceof Element);
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        sideLinks.forEach((link) => link.classList.remove('active'));
        document.querySelector(`.pd-side-nav a[href="#${entry.target.id}"]`)?.classList.add('active');
      });
    },
    { rootMargin: '-22% 0px -60% 0px', threshold: 0.01 },
  );
  observedSections.forEach((section) => sectionObserver.observe(section));

  const lightbox = document.getElementById('pd-lightbox') as HTMLDivElement | null;
  const lightboxImage = lightbox?.querySelector('img');
  const closeButton = lightbox?.querySelector('button');
  const closeLightbox = () => {
    if (!lightbox || !lightboxImage) return;
    lightbox.hidden = true;
  };
  document.querySelectorAll<HTMLButtonElement>('[data-full]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!lightbox || !lightboxImage) return;
      lightboxImage.src = button.dataset.full ?? '';
      lightboxImage.alt = button.dataset.alt ?? 'Project screenshot';
      lightbox.hidden = false;
    });
  });
  closeButton?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) closeLightbox();
  });
  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeLightbox();
  });
</script>
