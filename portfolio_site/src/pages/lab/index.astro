---
import ExperimentCard from '../../components/ExperimentCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPortfolioData } from '../../lib/portfolio-data';

const { config, experiments } = await getPortfolioData();
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={`Lab | ${config.name}`} description="Published experiments and prototypes.">
  <main class="min-h-screen bg-ink px-6 py-8 text-white lg:px-8">
    <div class="mx-auto max-w-7xl">
      <nav class="mb-10 flex flex-wrap items-center justify-between gap-4 border-b border-slate-700 pb-4">
        <a class="font-mono text-sm font-black uppercase tracking-[0.16em] text-signal" href={base}>
          Back To Portfolio
        </a>
        <span class="font-mono text-xs font-black uppercase tracking-[0.16em] text-slate-400">
          {experiments.length} published experiments
        </span>
      </nav>

      <SectionHeader
        eyebrow="Lab"
        title="Experimental Systems And Research Notes"
        copy="Fast static pages for prototypes, interface studies, and engineering experiments."
        inverse
      />

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {experiments.map((experiment) => (
          <ExperimentCard experiment={experiment} href={`${base}lab/${experiment.slug}/`} />
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
