---
import { getProjectHeroImage } from '../lib/portfolio-data';
import type { Project, SiteConfig, SiteThemeConfig } from '../lib/types';

type NormalizedThemeConfig = Required<SiteThemeConfig>;

interface Props {
  config: SiteConfig;
  projectCount: number;
  skillCount: number;
  experimentCount: number;
  theme: NormalizedThemeConfig;
  featuredProject?: Project;
}

const { config, projectCount, skillCount, experimentCount, theme, featuredProject } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const featuredImage = featuredProject ? getProjectHeroImage(featuredProject) : '';
const featuredHref = featuredProject ? `${base}projects/${featuredProject.slug}/` : `${base}#projects`;
const status = projectCount > 0 ? 'Available for software engineering roles' : 'Portfolio loading';
const showFeaturedPanel =
  theme.showFeaturedProjectPanel && theme.heroLayout !== 'statement';
const phoneHref = config.phone ? `tel:${config.phone.replace(/[^\d+]/g, '')}` : null;
const shortUrl = (url?: string | null) =>
  url?.replace(/^https?:\/\//, '').replace(/^www\./, '').replace(/\/$/, '') ?? null;
const contactLinks = [
  { label: 'Email', value: config.email, href: config.email ? `mailto:${config.email}` : null },
  { label: 'Phone', value: config.phone, href: phoneHref },
  { label: 'LinkedIn', value: shortUrl(config.linkedin_url), href: config.linkedin_url },
  { label: 'GitHub', value: shortUrl(config.github_url), href: config.github_url },
  { label: 'Instagram', value: shortUrl(config.instagram_url), href: config.instagram_url },
].filter((item) => item.value && item.href) as { label: string; value: string; href: string }[];
const heroClass = 'os-hero relative overflow-hidden border-b border-line bg-white text-ink';
---

<section class={heroClass}>
  <div class="os-hero-grid absolute inset-0 opacity-70"></div>
  <div class="absolute inset-x-0 top-0 h-1 bg-signal"></div>

  <div class="relative mx-auto max-w-7xl px-6 py-5 lg:px-8">
    <nav class="flex min-w-0 flex-wrap items-center justify-between gap-3 rounded-lg border border-line bg-white/90 px-4 py-3 shadow-sm backdrop-blur">
      <a class="shrink-0 font-mono text-sm font-black uppercase tracking-[0.14em] text-ink" href={base}>
        Eslam Tarek Nabawy
      </a>
      <div class="flex w-full max-w-full flex-wrap gap-2 font-mono text-xs font-black uppercase tracking-[0.12em] text-quiet sm:w-auto">
        <a class="rounded-full px-3 py-2 hover:bg-panel hover:text-signal" href="#projects">Projects</a>
        <a class="rounded-full px-3 py-2 hover:bg-panel hover:text-signal" href="#skills">Skills</a>
        <a class="rounded-full px-3 py-2 hover:bg-panel hover:text-signal" href="#experience">Experience</a>
        {config.email && <a class="rounded-full px-3 py-2 hover:bg-panel hover:text-signal" href={`mailto:${config.email}`}>Contact</a>}
      </div>
    </nav>

    <div class="grid gap-8 py-10 lg:grid-cols-[minmax(0,0.96fr)_minmax(360px,0.74fr)] lg:items-center lg:py-14">
      <div class="min-w-0">
        <div class="mb-5 flex max-w-full flex-wrap gap-3 font-mono text-xs font-black uppercase tracking-[0.14em]">
          <span class="max-w-full rounded-full border border-signal/40 bg-signal/10 px-3 py-2 leading-5 text-signal">
            {status}
          </span>
          <span class="w-full max-w-full rounded-full border border-line bg-white px-3 py-2 leading-5 text-quiet shadow-sm sm:w-auto">
            Flutter / Firebase / AI Automation / n8n
          </span>
          <span class="w-full max-w-full rounded-full border border-line bg-white px-3 py-2 leading-5 text-quiet shadow-sm sm:w-auto">
            6th October City, Egypt
          </span>
        </div>

        <h1 class="max-w-4xl break-words text-5xl font-black leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          {config.name}
        </h1>
        <p class="mt-5 max-w-3xl text-xl font-black leading-8 text-ink sm:text-2xl">
          {config.headline}
        </p>
        <p class="mt-5 max-w-3xl text-base leading-8 text-quiet">
          {config.bio}
        </p>

        <div class="mt-7 grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-2" aria-label="Contact information">
          {contactLinks.map((link) => (
            <a
              class="min-w-0 rounded-lg border border-line bg-white px-4 py-3 shadow-sm hover:border-signal hover:bg-panel"
              href={link.href}
            >
              <span class="block font-mono text-[0.68rem] font-black uppercase tracking-[0.14em] text-quiet">
                {link.label}
              </span>
              <span class="mt-1 block break-all text-sm font-black text-ink">{link.value}</span>
            </a>
          ))}
        </div>

        <div class="mt-7 flex flex-wrap gap-3">
          <a class="rounded-full border border-ink bg-ink px-5 py-3 text-sm font-black text-white" href="#projects">
            View Projects
          </a>
          {config.resume_url && (
            <a class="rounded-full border border-line bg-white px-5 py-3 text-sm font-black text-ink shadow-sm" href={config.resume_url}>
              Download Resume
            </a>
          )}
          {config.linkedin_url && (
            <a class="rounded-full border border-line bg-white px-5 py-3 text-sm font-black text-ink shadow-sm" href={config.linkedin_url}>
              LinkedIn
            </a>
          )}
        </div>
      </div>

      {showFeaturedPanel && (
        <aside class="min-w-0 rounded-lg border border-line bg-white p-4 shadow-xl shadow-slate-900/10">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-alert">
                Featured Build
              </p>
              <h2 class="mt-3 break-words text-3xl font-black leading-tight text-ink">
                {featuredProject?.title ?? 'Project pending'}
              </h2>
            </div>
            <span class="rounded-full border border-line bg-panel px-3 py-2 font-mono text-xs font-black uppercase tracking-[0.12em] text-quiet">
              #{projectCount}
            </span>
          </div>

          <p class="mt-4 line-clamp-3 text-sm leading-6 text-quiet">
            {featuredProject?.short_description ?? featuredProject?.description ?? 'Featured project will appear here.'}
          </p>

          <a href={featuredHref} class="mt-5 block overflow-hidden rounded-lg border border-line bg-panel">
            {featuredImage ? (
              <img
                src={featuredImage}
                alt={featuredProject ? `${featuredProject.title} preview` : 'Featured project preview'}
                class="aspect-[16/10] w-full object-cover transition duration-300 hover:scale-[1.02]"
              />
            ) : (
              <div class="os-radar aspect-[16/10] w-full"></div>
            )}
          </a>

          <dl class="mt-5 grid grid-cols-3 gap-3">
            <div class="border-r border-line pr-3">
              <dt class="font-mono text-[0.68rem] font-black uppercase tracking-[0.12em] text-quiet">
                Projects
              </dt>
              <dd class="mt-1 text-3xl font-black text-ink">{projectCount}</dd>
            </div>
            <div class="border-r border-line pr-3">
              <dt class="font-mono text-[0.68rem] font-black uppercase tracking-[0.12em] text-quiet">
                Roles
              </dt>
              <dd class="mt-1 text-3xl font-black text-ink">{experimentCount}</dd>
            </div>
            <div>
              <dt class="font-mono text-[0.68rem] font-black uppercase tracking-[0.12em] text-quiet">
                Skills
              </dt>
              <dd class="mt-1 text-3xl font-black text-ink">{skillCount}</dd>
            </div>
          </dl>
        </aside>
      )}
    </div>
  </div>
</section>
