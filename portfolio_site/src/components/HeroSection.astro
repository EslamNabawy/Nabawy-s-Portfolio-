---
import { getProjectHeroImage } from '../lib/portfolio-data';
import type { Project, SiteConfig } from '../lib/types';

interface Props {
  config: SiteConfig;
  projectCount: number;
  skillCount: number;
  experimentCount: number;
  featuredProject?: Project;
}

const { config, projectCount, skillCount, experimentCount, featuredProject } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const featuredImage = featuredProject ? getProjectHeroImage(featuredProject) : '';
const featuredHref = featuredProject ? `${base}projects/${featuredProject.slug}/` : `${base}#projects`;
const status = projectCount > 0 ? 'Portfolio live' : 'System initializing';
---

<section class="os-hero relative min-h-[92svh] overflow-hidden bg-ink text-white">
  {featuredImage && (
    <img
      src={featuredImage}
      alt={featuredProject ? `${featuredProject.title} interface preview` : 'Featured system preview'}
      class="absolute inset-0 h-full w-full object-cover opacity-25"
    />
  )}
  <div class="os-hero-grid absolute inset-0"></div>
  <div class="absolute inset-x-0 top-0 h-px bg-signal"></div>

  <div class="relative mx-auto flex min-h-[92svh] max-w-7xl flex-col px-6 py-6 lg:px-8">
    <nav class="flex min-w-0 flex-wrap items-center justify-between gap-4 border-b border-white/15 pb-4">
      <a class="shrink-0 font-mono text-sm font-black uppercase tracking-[0.18em] text-white" href={base}>
        Nabawy OS
      </a>
      <div class="flex w-full max-w-full flex-wrap gap-3 font-mono text-sm font-bold text-slate-300 sm:w-auto">
        <a class="hover:text-signal" href="#projects">Systems</a>
        <a class="hover:text-signal" href="#lab">Lab</a>
        <a class="hover:text-signal" href="#skills">Matrix</a>
        {config.email && <a class="hover:text-signal" href={`mailto:${config.email}`}>Contact</a>}
      </div>
    </nav>

    <div class="grid flex-1 content-between gap-10 py-10 lg:py-14">
      <div class="hero-copy-frame w-full">
        <div class="mb-5 flex max-w-full flex-wrap gap-3 font-mono text-xs font-black uppercase tracking-[0.16em]">
          <span class="max-w-full border border-signal/50 bg-signal/10 px-3 py-2 leading-5 text-signal">
            {status}
          </span>
          <span class="w-full max-w-full whitespace-normal break-words border border-white/15 bg-white/5 px-3 py-2 leading-5 text-slate-300 sm:w-auto">
            SSG / CMS / Admin Ready
          </span>
        </div>
        <h1 class="break-words text-5xl font-black leading-[0.92] text-white sm:text-7xl lg:text-8xl">
          {config.name}
        </h1>
        <p class="mt-6 max-w-3xl text-xl font-semibold leading-8 text-white sm:text-2xl">
          {config.headline}
        </p>
        <p class="mt-5 max-w-3xl text-base leading-8 text-slate-300">
          {config.bio}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="bg-white px-5 py-3 text-sm font-black text-ink" href="#projects">
            Review Systems
          </a>
          {config.github_url && (
            <a class="border border-white/25 px-5 py-3 text-sm font-black text-white" href={config.github_url}>
              Open GitHub
            </a>
          )}
          {config.resume_url && (
            <a class="border border-white/25 px-5 py-3 text-sm font-black text-white" href={config.resume_url}>
              Resume
            </a>
          )}
        </div>
      </div>

      <div class="hero-command-frame grid w-full gap-4 lg:max-w-none lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <a
          href={featuredHref}
          class="os-glass-panel group grid min-h-[220px] gap-5 p-5 sm:grid-cols-[1fr_1.05fr]"
        >
          <div class="flex min-w-0 flex-col justify-between">
            <div>
              <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-alert">
                Featured Dossier
              </p>
              <h2 class="mt-4 text-3xl font-black leading-tight text-white">
                {featuredProject?.title ?? 'System dossier pending'}
              </h2>
              <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-300">
                {featuredProject?.short_description ?? featuredProject?.description ?? 'Add a featured project in the CMS to light up this command surface.'}
              </p>
            </div>
            <span class="mt-6 font-mono text-xs font-black uppercase tracking-[0.16em] text-signal">
              Open Case File
            </span>
          </div>
          <div class="relative min-h-[180px] overflow-hidden border border-white/15 bg-ink">
            {featuredImage ? (
              <img
                src={featuredImage}
                alt={featuredProject ? `${featuredProject.title} preview` : 'Featured project preview'}
                class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
              />
            ) : (
              <div class="os-radar h-full min-h-[180px]"></div>
            )}
          </div>
        </a>

        <dl class="grid grid-cols-3 border border-white/15 bg-ink/75 backdrop-blur">
          <div class="border-r border-white/15 p-4">
            <dt class="font-mono text-xs font-black uppercase tracking-[0.14em] text-slate-400">
              Systems
            </dt>
            <dd class="mt-2 text-4xl font-black text-white">{projectCount}</dd>
          </div>
          <div class="border-r border-white/15 p-4">
            <dt class="font-mono text-xs font-black uppercase tracking-[0.14em] text-slate-400">
              Lab
            </dt>
            <dd class="mt-2 text-4xl font-black text-white">{experimentCount}</dd>
          </div>
          <div class="p-4">
            <dt class="font-mono text-xs font-black uppercase tracking-[0.14em] text-slate-400">
              Matrix
            </dt>
            <dd class="mt-2 text-4xl font-black text-white">{skillCount}</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
