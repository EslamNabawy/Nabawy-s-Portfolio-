---
import { getProjectHeroImage } from '../lib/portfolio-data';
import type { Project, SiteConfig, SiteThemeConfig } from '../lib/types';

type NormalizedThemeConfig = Required<SiteThemeConfig>;

interface Props {
  config: SiteConfig;
  theme: NormalizedThemeConfig;
  projects: Project[];
  featuredProject?: Project;
}

const { config, theme, projects, featuredProject } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const heroProjects = projects.length > 0 ? projects : featuredProject ? [featuredProject] : [];
const showFeaturedPanel =
  theme.showFeaturedProjectPanel && theme.heroLayout !== 'statement' && heroProjects.length > 0;
const phoneHref = config.phone ? `tel:${config.phone.replace(/[^\d+]/g, '')}` : null;
const heroActionLinks = [
  { label: 'Resume', href: config.resume_url, icon: 'resume', primary: true, download: true },
  { label: 'Work', href: '#projects', icon: 'work' },
  { label: 'Email', href: config.email ? `mailto:${config.email}` : null, icon: 'email' },
  { label: 'Phone', href: phoneHref, icon: 'phone' },
  { label: 'GitHub', href: config.github_url, icon: 'github' },
  { label: 'LinkedIn', href: config.linkedin_url, icon: 'linkedin' },
].filter((item) => item.href) as {
  label: string;
  href: string;
  icon: string;
  primary?: boolean;
  download?: boolean;
}[];
---

<section class="portfolio-hero">
  <div class="portfolio-hero__grid" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-5 py-5 sm:px-6 lg:px-8">
    <nav class="portfolio-nav">
      <a class="portfolio-nav__brand" href={base} aria-label="Home">EN</a>
      <div class="portfolio-nav__links">
        <a href="#projects">Work</a>
        <a href="#experience">Experience</a>
        <a href="#skills">Skills</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>

    <div class="portfolio-hero__layout">
      <div class="min-w-0">
        <p class="portfolio-hero__role">Software Engineer</p>

        <h1 class="portfolio-hero__title">{config.name}</h1>
        <p class="portfolio-hero__location">6th October City, Egypt</p>

        <div class="portfolio-hero__actions">
          {heroActionLinks.map((link) => (
            <a
              class:list={['portfolio-button', link.primary && 'portfolio-button--primary']}
              href={link.href}
              download={link.download}
            >
              <span class="portfolio-button__icon" aria-hidden="true" data-icon={link.icon}>
                {link.icon === 'resume' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M7 3h7l4 4v14H7z"></path>
                    <path d="M14 3v5h4"></path>
                    <path d="M9 13h6"></path>
                    <path d="M9 17h4"></path>
                  </svg>
                )}
                {link.icon === 'work' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M4 7h16v13H4z"></path>
                    <path d="M9 7V5h6v2"></path>
                    <path d="M4 12h16"></path>
                  </svg>
                )}
                {link.icon === 'email' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M4 6h16v12H4z"></path>
                    <path d="m4 7 8 6 8-6"></path>
                  </svg>
                )}
                {link.icon === 'phone' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M8 4 6 6c0 7 5 12 12 12l2-2-4-4-2 2c-2-1-3-2-4-4l2-2z"></path>
                  </svg>
                )}
                {link.icon === 'github' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M9 19c-4 1-4-2-5-3"></path>
                    <path d="M15 22v-3c0-1 .2-1.7-.5-2 2.7-.3 5.5-1.4 5.5-6A4.6 4.6 0 0 0 18.7 8c.1-.3.6-1.7-.1-3.4 0 0-1-.3-3.5 1.3a12 12 0 0 0-6.2 0C6.4 4.3 5.4 4.6 5.4 4.6 4.7 6.3 5.2 7.7 5.3 8A4.6 4.6 0 0 0 4 11c0 4.6 2.8 5.7 5.5 6-.7.3-.8 1-.8 2v3"></path>
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg viewBox="0 0 24 24">
                    <path d="M6 9v10"></path>
                    <path d="M6 5v.01"></path>
                    <path d="M11 19v-6a4 4 0 0 1 8 0v6"></path>
                    <path d="M11 9v10"></path>
                  </svg>
                )}
              </span>
              {link.label}
            </a>
          ))}
        </div>
      </div>

      {showFeaturedPanel && (
        <aside
          class="portfolio-featured"
          data-hero-project-carousel
          aria-label="Featured project carousel"
          tabindex="0"
        >
          <div class="portfolio-featured__header">
            <div>
              <p>Featured Work</p>
              <span data-hero-project-counter>1 / {heroProjects.length}</span>
            </div>
            <div class="portfolio-featured__controls" aria-label="Project carousel controls">
              <button type="button" data-hero-project-prev aria-label="Previous project">Prev</button>
              <button type="button" data-hero-project-next aria-label="Next project">Next</button>
            </div>
          </div>

          <div class="portfolio-featured__viewport">
            <div class="portfolio-featured__track" data-hero-project-track>
              {heroProjects.map((project, index) => {
                const projectHref = `${base}projects/${project.slug}/`;
                const projectImage = getProjectHeroImage(project);
                const projectStack = project.tech_stack.slice(0, 4);

                return (
                  <article
                    class="portfolio-featured__slide"
                    data-hero-project-slide
                    aria-hidden={index === 0 ? 'false' : 'true'}
                  >
                    <div class="portfolio-featured__slide-heading">
                      <div>
                        <h2>{project.title}</h2>
                      </div>
                      <a href={projectHref}>Open</a>
                    </div>

                    <p class="portfolio-featured__copy">
                      {project.short_description ?? project.description}
                    </p>

                    <a href={projectHref} class="portfolio-featured__media">
                      {projectImage ? (
                        <img src={projectImage} alt={`${project.title} preview`} />
                      ) : (
                        <div class="os-radar h-full w-full"></div>
                      )}
                    </a>

                    <div class="sr-only" aria-label={`${project.title} stack`}>
                      {projectStack.join(', ')}
                    </div>
                  </article>
                );
              })}
            </div>
          </div>

          <div class="portfolio-featured__dots" aria-label="Project carousel pagination">
            {heroProjects.map((project, index) => (
              <button
                type="button"
                data-hero-project-dot
                aria-label={`Show ${project.title}`}
                aria-current={index === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
        </aside>
      )}
    </div>
  </div>
</section>

<script>
  const setupHeroProjectCarousels = () => {
    document.querySelectorAll('[data-hero-project-carousel]').forEach((root) => {
      const track = root.querySelector<HTMLElement>('[data-hero-project-track]');
      const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-hero-project-slide]'));
      const prev = root.querySelector<HTMLButtonElement>('[data-hero-project-prev]');
      const next = root.querySelector<HTMLButtonElement>('[data-hero-project-next]');
      const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-hero-project-dot]'));
      const counter = root.querySelector<HTMLElement>('[data-hero-project-counter]');

      if (!track || !prev || !next || track.dataset.ready === 'true' || slides.length === 0) {
        return;
      }

      let activeIndex = 0;
      let autoRotationId: number | null = null;
      let isPaused = false;
      const autoRotationDelay = 2800;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const setActiveSlide = (nextIndex: number) => {
        activeIndex = (nextIndex + slides.length) % slides.length;
        track.style.transform = `translateX(-${activeIndex * 100}%)`;

        slides.forEach((slide, index) => {
          slide.setAttribute('aria-hidden', String(index !== activeIndex));
        });

        dots.forEach((dot, index) => {
          dot.setAttribute('aria-current', String(index === activeIndex));
        });

        if (counter) {
          counter.textContent = `${activeIndex + 1} / ${slides.length}`;
        }

        const hasMultipleSlides = slides.length > 1;
        prev.disabled = !hasMultipleSlides;
        next.disabled = !hasMultipleSlides;
      };

      const stopAutoRotation = () => {
        if (autoRotationId !== null) {
          window.clearInterval(autoRotationId);
          autoRotationId = null;
        }
      };

      const startAutoRotation = () => {
        if (prefersReducedMotion || isPaused || slides.length < 2 || autoRotationId !== null) {
          return;
        }

        autoRotationId = window.setInterval(() => {
          setActiveSlide(activeIndex + 1);
        }, autoRotationDelay);
      };

      const restartAutoRotation = () => {
        stopAutoRotation();
        startAutoRotation();
      };

      const goToSlide = (nextIndex: number) => {
        setActiveSlide(nextIndex);
        restartAutoRotation();
      };

      prev.addEventListener('click', () => goToSlide(activeIndex - 1));
      next.addEventListener('click', () => goToSlide(activeIndex + 1));
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => goToSlide(index));
      });

      root.addEventListener('keydown', (event) => {
        if (event instanceof KeyboardEvent && event.key === 'ArrowLeft') {
          goToSlide(activeIndex - 1);
        }
        if (event instanceof KeyboardEvent && event.key === 'ArrowRight') {
          goToSlide(activeIndex + 1);
        }
      });

      root.addEventListener('pointerenter', () => {
        isPaused = true;
        stopAutoRotation();
      });

      root.addEventListener('pointerleave', () => {
        isPaused = false;
        startAutoRotation();
      });

      root.addEventListener('focusin', () => {
        isPaused = true;
        stopAutoRotation();
      });

      root.addEventListener('focusout', (event) => {
        const focusEvent = event as FocusEvent;
        if (!root.contains(focusEvent.relatedTarget as Node | null)) {
          isPaused = false;
          startAutoRotation();
        }
      });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          stopAutoRotation();
        } else {
          startAutoRotation();
        }
      });

      track.dataset.ready = 'true';
      setActiveSlide(0);
      startAutoRotation();
    });
  };

  setupHeroProjectCarousels();
  document.addEventListener('astro:page-load', setupHeroProjectCarousels);
</script>
