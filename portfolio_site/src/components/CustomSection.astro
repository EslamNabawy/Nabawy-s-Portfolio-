---
import type { PageSection, SectionBlock, SectionBlockItem } from '../lib/types';
import { readSectionBlocks } from '../lib/section-blocks';

const { section } = Astro.props as { section: PageSection };
const blocks = readSectionBlocks(section.content_json);
const hasMedia = blocks.some((block) => block.type === 'media' && block.mediaUrl);
const sectionTitleId = `section-${section.section_key}-title`;
const classes = [
  'custom-section',
  `custom-section--${section.tone}`,
  `custom-section--${section.layout}`,
  `custom-section--${section.density}`,
  `custom-section--${section.alignment}`,
  `custom-section--${section.section_type}`,
  hasMedia ? 'custom-section--has-media' : '',
].join(' ');

const itemLinkLabel = (item: SectionBlockItem) =>
  `Open ${item.title || item.label || 'item'}`;

const hasItems = (block: SectionBlock) => (block.items?.length ?? 0) > 0;
const hasActions = (block: SectionBlock) => (block.actions?.length ?? 0) > 0;
---

<section class={classes} id={section.section_key} aria-labelledby={sectionTitleId}>
  <div class="custom-section__inner">
    <div class="custom-section__header">
      {section.eyebrow && <p class="custom-section__eyebrow">{section.eyebrow}</p>}
      <h2 id={sectionTitleId}>{section.title}</h2>
      {section.body && <p class="custom-section__body">{section.body}</p>}
    </div>

    {blocks.map((block) => (
      <>
        {(block.type === 'heroText' || block.type === 'callout') && (
          <article class={`custom-section__block custom-section__block--${block.type}`}>
            {block.label && <p class="custom-section__item-label">{block.label}</p>}
            {block.title && <h3>{block.title}</h3>}
            {block.copy && <p>{block.copy}</p>}
            {block.url && <a href={block.url}>Open</a>}
          </article>
        )}

        {block.type === 'media' && block.mediaUrl && (
          <figure class="custom-section__media">
            <img
              src={block.mediaUrl}
              alt={block.altText || block.caption || section.title}
              loading="lazy"
            />
            {block.caption && <figcaption>{block.caption}</figcaption>}
          </figure>
        )}

        {hasItems(block) && (
          <div class={`custom-section__items custom-section__items--${block.type}`}>
            {block.items?.map((item, index) => (
              <article class="custom-section__item">
                <p class="custom-section__item-label">
                  {item.label || String(index + 1).padStart(2, '0')}
                </p>
                {item.title && <h3>{item.title}</h3>}
                {item.copy && <p>{item.copy}</p>}
                {item.url && <a aria-label={itemLinkLabel(item)} href={item.url}>Open</a>}
              </article>
            ))}
          </div>
        )}

        {hasActions(block) && (
          <div class="custom-section__actions">
            {block.actions?.map((action) => (
              <a href={action.url}>{action.label}</a>
            ))}
          </div>
        )}
      </>
    ))}
  </div>
</section>
