---
import { getProjectHeroImage } from '../lib/portfolio-data';
import type { Project, SiteThemeConfig } from '../lib/types';

type ProjectCardStyle = NonNullable<SiteThemeConfig['projectCardStyle']>;

interface Props {
  project: Project;
  prominent?: boolean;
  styleVariant?: ProjectCardStyle;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const heroImage = getProjectHeroImage(project);
const summary = project.short_description ?? project.description;
const caseNumber = String(index + 1).padStart(2, '0');
const stackLabel = project.tech_stack.slice(0, 3).join(' / ') || 'Project';
---

<article class="portfolio-project-card">
  <a href={`${base}projects/${project.slug}/`} class="portfolio-project-card__link">
    <div class="portfolio-project-card__media">
      <img src={heroImage} alt={`${project.title} preview`} loading="lazy" />
      <span>Case {caseNumber}</span>
    </div>

    <div class="portfolio-project-card__body">
      <div class="portfolio-project-card__meta">
        <span>{project.featured ? 'Featured' : 'Project'}</span>
        <span>{stackLabel}</span>
      </div>

      <h3>{project.title}</h3>
      <p>{summary}</p>

      {(project.role || project.impact) && (
        <dl class="portfolio-project-card__proof">
          {project.role && (
            <div>
              <dt>Role</dt>
              <dd>{project.role}</dd>
            </div>
          )}
          {project.impact && (
            <div>
              <dt>Impact</dt>
              <dd>{project.impact}</dd>
            </div>
          )}
        </dl>
      )}

      <div class="portfolio-project-card__stack">
        {project.tech_stack.slice(0, 6).map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </div>
  </a>
</article>
