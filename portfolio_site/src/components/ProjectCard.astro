---
import type { Project } from '../lib/types';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="group border border-line bg-white shadow-sm transition hover:border-ink">
  <a href={`/projects/${project.slug}/`} class="block">
    <img
      src={project.image_url ?? ''}
      alt={`${project.title} preview`}
      loading="lazy"
      class="aspect-[16/10] w-full border-b border-line object-cover"
    />
    <div class="p-5">
      <div class="flex items-start justify-between gap-4">
        <h3 class="text-xl font-black text-ink">{project.title}</h3>
        <span class="whitespace-nowrap border border-line px-2 py-1 text-xs font-bold uppercase text-signal">
          Case File
        </span>
      </div>
      <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">
        {project.description}
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        {project.tech_stack.map((item) => (
          <span class="border border-line bg-panel px-2 py-1 text-xs font-bold text-slate-700">
            {item}
          </span>
        ))}
      </div>
    </div>
  </a>
</article>
