---
import type { Experiment } from '../lib/types';

interface Props {
  experiment: Experiment;
}

const { experiment } = Astro.props;
const statusClass = {
  prototype: 'text-alert',
  active: 'text-signal',
  archived: 'text-oxide',
}[experiment.status];
---

<article class="group border border-line bg-white transition hover:border-ink">
  <a href={`/lab/${experiment.slug}/`} class="block h-full min-w-0 p-5">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class={`text-xs font-black uppercase tracking-[0.16em] ${statusClass}`}>
          {experiment.status}
        </p>
        <h3 class="mt-3 text-2xl font-black leading-tight text-ink">
          {experiment.title}
        </h3>
      </div>
      <span class="whitespace-nowrap border border-line px-2 py-1 text-xs font-bold text-quiet">
        Lab
      </span>
    </div>

    <p class="mt-4 line-clamp-4 text-sm leading-6 text-quiet">
      {experiment.summary}
    </p>

    {experiment.media_url ? (
      <img
        src={experiment.media_url}
        alt={`${experiment.title} experiment preview`}
        loading="lazy"
        class="mt-5 aspect-[16/9] w-full border border-line bg-panel object-cover"
      />
    ) : (
      <div class="mt-5 flex aspect-[16/9] items-center justify-center border border-line bg-panel">
        <span class="text-xs font-black uppercase tracking-[0.16em] text-quiet">
          Research Note
        </span>
      </div>
    )}

    <div class="mt-5 flex items-center justify-between border-t border-line pt-4 text-xs font-black uppercase tracking-[0.14em]">
      <span class="text-quiet">{experiment.category}</span>
      <span class="text-signal">Open File</span>
    </div>
  </a>
</article>
