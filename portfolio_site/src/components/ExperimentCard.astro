---
import type { Experiment } from '../lib/types';

interface Props {
  experiment: Experiment;
  href?: string;
}

const { experiment, href } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const targetHref = href ?? `${base}lab/${experiment.slug}/`;
const statusClass = {
  prototype: 'text-alert',
  active: 'text-signal',
  archived: 'text-oxide',
}[experiment.status];
---

<article class="portfolio-experience-card group">
  <a href={targetHref} class="block h-full min-w-0 p-5">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class={`font-mono text-xs font-black uppercase tracking-[0.16em] ${statusClass}`}>
          {experiment.status}
        </p>
        <h3 class="mt-3 text-2xl font-black leading-tight text-white">
          {experiment.title}
        </h3>
      </div>
      <span class="whitespace-nowrap rounded-full border border-white/10 bg-white/5 px-3 py-1 font-mono text-xs font-bold text-slate-300">
        Experience
      </span>
    </div>

    <p class="mt-4 line-clamp-4 text-sm leading-6 text-slate-300">
      {experiment.summary}
    </p>

    {experiment.media_url ? (
      <img
        src={experiment.media_url}
        alt={`${experiment.title} experiment preview`}
        loading="lazy"
        class="mt-5 aspect-[16/9] w-full rounded-lg border border-white/10 bg-slate-950 object-cover transition duration-300 group-hover:scale-[1.01]"
      />
    ) : (
      <div class="os-radar mt-5 flex aspect-[16/9] items-center justify-center rounded-lg border border-white/10 bg-slate-950">
        <span class="relative z-10 bg-slate-950 px-2 font-mono text-xs font-black uppercase tracking-[0.16em] text-slate-300">
          Resume Proof
        </span>
      </div>
    )}

    <div class="mt-5 flex items-center justify-between border-t border-white/10 pt-4 font-mono text-xs font-black uppercase tracking-[0.14em]">
      <span class="text-slate-400">{experiment.category}</span>
      <span class="text-signal">Details</span>
    </div>
  </a>
</article>
