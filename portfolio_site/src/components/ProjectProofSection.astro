---
import type { Project, SiteThemeConfig } from '../lib/types';
import ProjectCard from './ProjectCard.astro';

type ProjectCardStyle = NonNullable<SiteThemeConfig['projectCardStyle']>;

interface Props {
  projects: Project[];
  featuredCount: number;
  cardStyle: ProjectCardStyle;
}

const { projects, featuredCount, cardStyle } = Astro.props;
---

<section class="portfolio-work" id="projects">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="portfolio-section-heading portfolio-section-heading--split">
      <div>
        <p>Selected Work</p>
        <h2>Case studies that show the engineering.</h2>
      </div>
      <div class="portfolio-work__stats">
        <span><strong>{projects.length}</strong> projects</span>
        <span><strong>{featuredCount}</strong> featured</span>
      </div>
    </div>

    {projects.length > 0 ? (
      <div class="portfolio-work__carousel" data-project-carousel>
        <div class="portfolio-work__controls">
          <p>Screenshot-backed apps, automation, and product systems.</p>
          <div>
            <button type="button" data-project-carousel-prev>Prev</button>
            <button type="button" data-project-carousel-next>Next</button>
          </div>
        </div>

        <div class="project-carousel-track portfolio-work__track" data-project-carousel-track tabindex="0">
          {projects.map((project, index) => (
            <div class="portfolio-work__slide" data-project-card-slide>
              <ProjectCard
                project={project}
                prominent={false}
                styleVariant={cardStyle}
                index={index}
              />
            </div>
          ))}
        </div>
      </div>
    ) : (
      <div class="portfolio-empty-state">
        <p>Awaiting Project</p>
        <span>Publish the first project from the dashboard.</span>
      </div>
    )}
  </div>
</section>

<script>
  const setupProjectCarousels = () => {
    document.querySelectorAll('[data-project-carousel]').forEach((root) => {
      const track = root.querySelector<HTMLElement>('[data-project-carousel-track]');
      const prev = root.querySelector<HTMLButtonElement>('[data-project-carousel-prev]');
      const next = root.querySelector<HTMLButtonElement>('[data-project-carousel-next]');

      if (!track || !prev || !next || track.dataset.ready === 'true') {
        return;
      }

      const slideStep = () => {
        const firstSlide = track.querySelector<HTMLElement>('[data-project-card-slide]');
        return firstSlide ? firstSlide.getBoundingClientRect().width + 20 : track.clientWidth * 0.85;
      };

      const updateControls = () => {
        const maxScroll = track.scrollWidth - track.clientWidth;
        prev.disabled = track.scrollLeft <= 4;
        next.disabled = track.scrollLeft >= maxScroll - 4;
      };

      prev.addEventListener('click', () => {
        track.scrollBy({ left: -slideStep(), behavior: 'smooth' });
      });

      next.addEventListener('click', () => {
        track.scrollBy({ left: slideStep(), behavior: 'smooth' });
      });

      track.addEventListener('scroll', updateControls, { passive: true });
      window.addEventListener('resize', updateControls);
      track.dataset.ready = 'true';
      updateControls();
    });
  };

  setupProjectCarousels();
  document.addEventListener('astro:page-load', setupProjectCarousels);
</script>
