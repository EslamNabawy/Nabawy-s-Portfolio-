---
import type { Project, SiteThemeConfig } from '../lib/types';
import ProjectCard from './ProjectCard.astro';
import SectionHeader from './SectionHeader.astro';

type ProjectCardStyle = NonNullable<SiteThemeConfig['projectCardStyle']>;

interface Props {
  projects: Project[];
  featuredCount: number;
  cardStyle: ProjectCardStyle;
}

const { projects, featuredCount, cardStyle } = Astro.props;
const prominentFirst = cardStyle === 'visual';
const gridClass =
  cardStyle === 'compact'
    ? 'mt-8 grid gap-4'
    : 'mt-8 grid gap-5 md:grid-cols-2';
---

<section class="border-b border-line bg-white px-6 py-12 lg:px-8" id="projects">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col justify-between gap-6 border-b border-line pb-8 lg:flex-row lg:items-end">
      <SectionHeader
        eyebrow="Selected Projects"
        title="Proof Of Work"
        copy="Two Flutter/Firebase builds from the resume, focused on stack, role, and delivery value."
      />
      <div class="grid w-full max-w-md grid-cols-2 border border-line bg-panel">
        <div class="border-r border-line p-4">
          <p class="font-mono text-xs font-black uppercase tracking-[0.14em] text-quiet">
            Projects
          </p>
          <p class="mt-1 text-4xl font-black text-ink">{projects.length}</p>
        </div>
        <div class="p-4">
          <p class="font-mono text-xs font-black uppercase tracking-[0.14em] text-quiet">
            Featured
          </p>
          <p class="mt-1 text-4xl font-black text-ink">{featuredCount}</p>
        </div>
      </div>
    </div>

    <div class={gridClass}>
      {projects.map((project, index) => (
        <ProjectCard
          project={project}
          prominent={prominentFirst && index === 0}
          styleVariant={cardStyle}
          index={index}
        />
      ))}
      {projects.length === 0 && (
        <div class="border border-line bg-panel p-6">
          <p class="font-mono text-xs font-black uppercase tracking-[0.16em] text-alert">
            Awaiting Project
          </p>
          <p class="mt-4 text-sm leading-7 text-quiet">
            Publish the first project from the dashboard.
          </p>
        </div>
      )}
    </div>
  </div>
</section>
