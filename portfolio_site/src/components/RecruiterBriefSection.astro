---
import SectionHeader from './SectionHeader.astro';

interface Props {
  facts: readonly [string, string, string][];
}

const { facts } = Astro.props;
---

<section class="portfolio-brief" id="summary">
  <div class="mx-auto max-w-7xl px-5 py-14 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="Recruiter Brief"
      title="What To Know In 30 Seconds"
      copy="Flutter engineer with practical app delivery, Firebase experience, mentorship history, and computer science fundamentals."
      inverse
    />
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {facts.map(([label, title, copy]) => (
        <article class="portfolio-brief-card">
          <p>
            {label}
          </p>
          <h3>{title}</h3>
          <span>{copy}</span>
        </article>
      ))}
    </div>
  </div>
</section>
