---
interface Props {
  eyebrow: string;
  title: string;
  copy?: string;
}

const { eyebrow, title, copy } = Astro.props;
---

<header class="mb-8 max-w-3xl">
  <p class="mb-2 text-xs font-black uppercase tracking-[0.18em] text-signal">
    {eyebrow}
  </p>
  <h2 class="text-3xl font-black text-ink sm:text-4xl">{title}</h2>
  {copy && <p class="mt-3 text-base leading-7 text-slate-600">{copy}</p>}
</header>
