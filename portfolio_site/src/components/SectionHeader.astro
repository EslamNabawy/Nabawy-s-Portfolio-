---
interface Props {
  eyebrow: string;
  title: string;
  copy?: string;
}

const { eyebrow, title, copy } = Astro.props;
---

<header class="mb-8 max-w-4xl">
  <p class="mb-3 text-xs font-black uppercase tracking-[0.18em] text-signal">
    {eyebrow}
  </p>
  <h2 class="text-3xl font-black leading-tight text-ink sm:text-5xl">{title}</h2>
  {copy && <p class="mt-4 max-w-2xl text-base leading-7 text-quiet">{copy}</p>}
</header>
